---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
}

const {
  title       = 'Efi Solution — Webs de velocidad extrema que escalan tu facturación',
  description = 'Agencia tecnológica de élite. Construimos plataformas web ultrarrápidas con código impecable. Más conversión, menos rebote. Auditoría de rendimiento gratuita.',
  canonical   = Astro.url.href,
  ogImage     = '/og-image.jpg',
  ogImageAlt  = 'Efi Solution — Plataformas web de velocidad extrema hechas en Colombia',
} = Astro.props;

const siteName  = 'Efi Solution';
const themeColor = '#0a0a0b';

// OG images MUST be absolute URLs — relative paths fail on WhatsApp, LinkedIn, etc.
const ogImageAbsolute = ogImage.startsWith('http')
  ? ogImage
  : new URL(ogImage, Astro.site ?? Astro.url.origin).href;

const fontsUrl =
  'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap';

// Structured data
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Efi Solution',
  url: 'https://efisolution.com',
  logo: 'https://efisolution.com/favicon.svg',
  description,
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'CO',
  },
  founder: [
    { '@type': 'Person', name: 'Juan Manuel', jobTitle: 'CTO — Ingeniero Mecatrónico & Full-Stack Developer' },
    { '@type': 'Person', name: 'Sarai',       jobTitle: 'Head of UX & Client Strategy' },
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    availableLanguage: ['es', 'en'],
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: 'https://efisolution.com',
};
---

<!doctype html>
<html lang="es-CO" class="dark scroll-smooth">
  <head>
    <!-- ─── Charset & Viewport ─────────────────────────────────── -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="format-detection" content="telephone=no" />

    <!-- ─── Theme & Color Scheme ──────────────────────────────── -->
    <meta name="theme-color" content={themeColor} />
    <meta name="color-scheme" content="dark" />
    <meta name="msapplication-TileColor" content={themeColor} />

    <!-- ─── Primary SEO ───────────────────────────────────────── -->
    <title>{title}</title>
    <meta name="description"  content={description} />
    <meta name="author"       content="Juan Manuel & Sarai — Efi Solution" />
    <meta name="keywords"     content="desarrollo web premium, agencia tecnológica Colombia, web ultrarrápida, Astro, arquitectura backend, Core Web Vitals, desarrollo a medida" />
    <meta name="robots"       content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="generator"    content={Astro.generator} />
    <link rel="canonical"     href={canonical} />

    <!-- ─── Open Graph ────────────────────────────────────────── -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content={siteName} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:image"       content={ogImageAbsolute} />
    <meta property="og:image:width"  content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt"   content={ogImageAlt} />
    <meta property="og:locale"      content="es_CO" />

    <!-- ─── Twitter / X Cards ────────────────────────────────── -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageAbsolute} />
    <meta name="twitter:image:alt"   content={ogImageAlt} />

    <!-- ─── Favicons & PWA ────────────────────────────────────── -->
    <link rel="icon"             type="image/svg+xml"  href="/favicon.svg" />
    <link rel="apple-touch-icon"                       href="/apple-touch-icon.png" />
    <link rel="manifest"                               href="/manifest.webmanifest" />

    <!-- ─── Fonts: preconnect first, then non-blocking load ───── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!--
      Load fonts non-blocking:
      1. preload announces the resource early
      2. media="print" → onload trick makes it non-render-blocking
      3. <noscript> ensures it loads for users with JS disabled
    -->
    <link
      rel="preload"
      as="style"
      href={fontsUrl}
    />
    <link
      rel="stylesheet"
      href={fontsUrl}
      media="print"
      onload="this.media='all';this.onload=null"
    />
    <noscript>
      <link rel="stylesheet" href={fontsUrl} />
    </noscript>

    <!-- ─── Structured Data ───────────────────────────────────── -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </head>

  <body>
    <!-- Skip-to-content for keyboard & screen reader users -->
    <a
      href="#contenido"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[9999] focus:rounded-lg focus:bg-accent-500 focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-white focus:shadow-glow-accent focus:outline-none"
    >
      Saltar al contenido principal
    </a>

    <!-- Ambient background — pointer-events none, decorative only -->
    <div aria-hidden="true" class="site-ambient">
      <div class="site-ambient__grid"></div>
      <div class="site-ambient__glow"></div>
    </div>

    <main id="contenido" class="relative isolate" tabindex="-1">
      <slot />
    </main>
  </body>
</html>
