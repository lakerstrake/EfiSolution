---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
}

const {
  title = 'Efi Solution - Webs rapidas para crecer ventas',
  description = 'Agencia tecnologica de alto rendimiento. Disenamos y desarrollamos experiencias web rapidas, claras y listas para escalar.',
  canonical = Astro.url.href,
  ogImage = '/og-image.jpg',
  ogImageAlt = 'Efi Solution - Desarrollo web profesional',
} = Astro.props;

const siteName = 'Efi Solution';

const ogImageAbsolute = ogImage.startsWith('http')
  ? ogImage
  : new URL(ogImage, Astro.site ?? Astro.url.origin).href;

const fontsUrl =
  'https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700;800&display=swap';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Efi Solution',
  url: 'https://efisolution.com',
  logo: 'https://efisolution.com/favicon.svg',
  description,
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'CO',
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: 'https://efisolution.com',
};
---

<!doctype html>
<html lang="es-CO" class="scroll-smooth">
  <head>
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem('theme');
        const theme = savedTheme || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="format-detection" content="telephone=no" />

    <meta name="theme-color" id="meta-theme-color" content="#f8fafc" />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      (function () {
        const theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
        const tag = document.getElementById('meta-theme-color');
        if (tag) {
          tag.setAttribute('content', theme === 'dark' ? '#09090b' : '#f8fafc');
        }
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="es_CO" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={fontsUrl} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </head>

  <body>
    <a
      href="#contenido"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[9999] focus:rounded-md focus:bg-accent-500 focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-white"
    >
      Saltar al contenido principal
    </a>

    <Navbar />

    <div aria-hidden="true" class="site-ambient">
      <div class="site-ambient__grid"></div>
      <div class="site-ambient__glow"></div>
    </div>

    <main id="contenido" class="relative isolate" tabindex="-1">
      <slot />
    </main>
  </body>
</html>
