---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import { supportedLocales, getSiteContent, type Locale } from '../i18n/siteContent';
import { equivalentPath } from '../lib/altRoutes';
import { PRICING_BY_LOCALE, planOrder } from '../config/pricing';
import { CF_ANALYTICS_TOKEN, SITE } from '../config/site';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
}

const {
  locale,
  title = 'Efi Solution',
  description = 'High-performance digital solutions.',
  canonical = Astro.url.href,
  ogImage = '/og-image.jpg',
  ogImageAlt = 'Efi Solution',
} = Astro.props;

const siteName = SITE.name;
const localeMap: Record<Locale, string> = {
  es: 'es_CO',
  en: 'en_US',
  pt: 'pt_BR',
  fr: 'fr_FR',
};
const skipLabelMap: Record<Locale, string> = {
  es: 'Saltar al contenido principal',
  en: 'Skip to main content',
  pt: 'Ir para o conteudo principal',
  fr: 'Aller au contenu principal',
};

// hreflang por página: cada idioma apunta a la RUTA EQUIVALENTE de la página
// actual (privacidad ↔ privacy, etc.), no a la home. Base: SITE.url.
const origin = SITE.url;
const currentPath = Astro.url.pathname;
const alternates = supportedLocales.map((item) => ({
  code: item,
  href: new URL(equivalentPath(item, currentPath), origin).href,
}));
const xDefaultHref = new URL(equivalentPath('es', currentPath), origin).href;

const ogImageAbsolute = ogImage.startsWith('http')
  ? ogImage
  : new URL(ogImage, Astro.site ?? Astro.url.origin).href;

const content = getSiteContent(locale);

// SEO local: ficha de negocio en Bogotá. Las URLs siguen a Astro.site, así que
// al cambiar el dominio en astro.config.mjs se actualizan solas.
// Catálogo de servicios (sin precio, para no publicar montos placeholder).
const offerCatalog = {
  '@type': 'OfferCatalog',
  name: content.pricing.title,
  itemListElement: Object.values(content.pricing.plans).map((plan) => ({
    '@type': 'Offer',
    itemOffered: {
      '@type': 'Service',
      name: plan.name,
      description: plan.tagline,
    },
  })),
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': ['Organization', 'ProfessionalService'],
  '@id': `${origin}#business`,
  name: SITE.name,
  url: origin,
  logo: new URL('/favicon.svg', origin).href,
  image: ogImageAbsolute,
  description,
  email: SITE.email,
  ...(SITE.whatsapp ? { telephone: `+${SITE.whatsapp}` } : {}),
  priceRange: '$$',
  sameAs: [
    'https://github.com/lakerstrake',
    'https://www.linkedin.com/in/juanmlagosm/',
  ],
  areaServed: [
    { '@type': 'City', name: 'Bogotá' },
    { '@type': 'Country', name: 'Colombia' },
  ],
  knowsAbout: [
    'Diseño web',
    'Páginas web para negocios',
    'Rendimiento web',
    'Automatización con IA',
    'SEO local',
  ],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Bogotá',
    addressRegion: 'Bogotá D.C.',
    addressCountry: 'CO',
  },
  makesOffer: offerCatalog,
};

// Caso de cliente real (Búho Repuestos) como dato estructurado.
const clientCaseSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: 'Búho Repuestos B&M',
  about: content.clientCase.title,
  description: content.clientCase.problem,
  url: 'https://buhorepuestos.com',
  creator: { '@id': `${origin}#business` },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: origin,
};

// Un Service por plan, con el precio mensual en la MONEDA que esta página ya
// muestra (ES→COP, EN→USD, PT→BRL, FR→EUR). El precio se normaliza a dígitos
// ('290.000' → '290000') porque schema.org no admite separadores de miles.
const currencyByLocale: Record<Locale, string> = { es: 'COP', en: 'USD', pt: 'BRL', fr: 'EUR' };
const servicesSchema = planOrder.map((key) => {
  const plan = content.pricing.plans[key];
  const amount = PRICING_BY_LOCALE[locale].plans[key];
  return {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: plan.name,
    description: plan.tagline,
    provider: { '@id': `${origin}#business` },
    offers: {
      '@type': 'Offer',
      price: amount.price.replace(/\D/g, ''),
      priceCurrency: currencyByLocale[locale],
    },
  };
});

// Reseña real de Cristian (Búho Repuestos) — mismo texto visible en la página.
const firstTestimonial = content.testimonials.items[0];
const reviewSchema = {
  '@context': 'https://schema.org',
  '@type': 'Review',
  itemReviewed: { '@type': 'Organization', '@id': `${origin}#business`, name: SITE.name },
  author: { '@type': 'Person', name: firstTestimonial.name },
  reviewBody: firstTestimonial.quote,
  reviewRating: { '@type': 'Rating', ratingValue: 5, bestRating: 5 },
};
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <ClientRouter />
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem('theme');
        const theme = savedTheme || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="format-detection" content="telephone=no" />

    <meta name="theme-color" id="meta-theme-color" content="#f8fafc" />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      (function () {
        const theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
        const tag = document.getElementById('meta-theme-color');
        if (tag) {
          tag.setAttribute('content', theme === 'dark' ? '#09090b' : '#f8fafc');
        }
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={localeMap[locale]} />
    {supportedLocales
      .filter((item) => item !== locale)
      .map((item) => (
        <meta property="og:locale:alternate" content={localeMap[item]} />
      ))}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:alt" content={ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.code} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
    {alternates
      .filter((alt) => alt.code !== locale)
      .map((alt) => (
        <link rel="prefetch" href={alt.href} as="document" />
      ))}

    {/* Self-hosted fonts: preload the above-the-fold latin subsets (Sora heading, Manrope body) */}
    <link rel="preload" as="font" type="font/woff2" href="/fonts/sora-latin.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/manrope-latin.woff2" crossorigin />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(clientCaseSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(servicesSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />
  </head>

  <body class="w-full overflow-x-hidden">
    <div id="scroll-progress" aria-hidden="true" class="scroll-progress"></div>
    <a
      href="#contenido"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[9999] focus:rounded-md focus:bg-accent-500 focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-white"
    >
      {skipLabelMap[locale]}
    </a>

    <Navbar locale={locale} />

    <div aria-hidden="true" class="site-ambient">
      <div class="site-ambient__grid"></div>
      <div class="site-ambient__glow"></div>
    </div>

    <main id="contenido" class="relative isolate" tabindex="-1">
      <slot />
    </main>

    <WhatsAppFloat locale={locale} />

    <script is:inline>
      (function () {
        // Body is replaced on every View Transition, so this inline script re-runs.
        // Clean up the previous navigation's listener before adding a new one.
        if (window._spCleanup) { window._spCleanup(); }
        var bar = document.getElementById('scroll-progress');
        if (!bar) return;
        var fn = function () {
          var t = window.scrollY || document.documentElement.scrollTop;
          var h = document.documentElement.scrollHeight - window.innerHeight;
          bar.style.transform = 'scaleX(' + (h > 0 ? Math.min(t / h, 1) : 0) + ')';
        };
        fn();
        window.addEventListener('scroll', fn, { passive: true });
        window._spCleanup = function () { window.removeEventListener('scroll', fn); };
      })();
    </script>

    <script is:inline>
      function initReveal() {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduced) {
          document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in-view'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -56px 0px' }
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      }
      // astro:page-load fires on first load AND after every navigation
      document.addEventListener('astro:page-load', initReveal);
    </script>

    {CF_ANALYTICS_TOKEN && (
      <Fragment
        set:html={`<script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "${CF_ANALYTICS_TOKEN}"}'></script>`}
      />
    )}
  </body>
</html>
