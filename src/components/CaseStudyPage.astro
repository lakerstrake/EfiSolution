---
import Layout from '../layouts/Layout.astro';
import { getSiteContent, localeHref, type Locale } from '../i18n/siteContent';
import { whatsappHref } from '../lib/whatsapp';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = getSiteContent(locale);
const t = content.casePage;
const testimonial = content.testimonials.items[0];
const verifiedLabel = content.testimonials.verifiedLabel;
const waHref = whatsappHref(t.waMessage);
const siteUrl = 'https://buhorepuestos.com';
---

<Layout locale={locale} title={t.metaTitle} description={t.metaDescription}>
  <section class="section-padding pt-28 sm:pt-32" aria-labelledby="case-title">
    <div class="container-x">
      <div class="mx-auto max-w-4xl">
        <span class="eyebrow border-emerald-500/30 bg-emerald-500/10 text-emerald-700 dark:text-emerald-400">
          <span class="eyebrow-dot" style="background-color:#10b981;box-shadow:0 0 14px 2px rgba(16,185,129,0.45)"></span>
          {t.badge}
        </span>

        <h1 id="case-title" class="mt-6 font-display text-fluid-4xl font-semibold leading-[1.06] tracking-tightest text-zinc-900 dark:text-white">
          {t.title}
        </h1>
        <p class="mt-4 max-w-2xl text-fluid-base leading-relaxed text-zinc-600 dark:text-zinc-400">{t.intro}</p>

        <div class="mt-8 overflow-hidden rounded-2xl border border-zinc-200 bg-zinc-100 shadow-sm dark:border-white/10 dark:bg-zinc-900">
          <div class="flex items-center gap-2 border-b border-zinc-200 px-3 py-2 dark:border-white/10">
            <span class="h-2 w-2 rounded-full bg-red-500/60"></span>
            <span class="h-2 w-2 rounded-full bg-amber-500/60"></span>
            <span class="h-2 w-2 rounded-full bg-emerald-500/60"></span>
            <span class="ml-2 truncate text-[11px] font-medium text-zinc-600 dark:text-zinc-400">buhorepuestos.com</span>
          </div>
          <picture>
            <source srcset="/buho.avif" type="image/avif" />
            <source srcset="/buho.webp" type="image/webp" />
            <img src="/buho.png" alt="Búho Repuestos B&M" width="1280" height="853" loading="eager" fetchpriority="high" decoding="async" class="w-full object-cover" />
          </picture>
        </div>

        <div class="mt-10 grid gap-10 lg:grid-cols-12 lg:gap-12">
          <div class="min-w-0 space-y-8 lg:col-span-7">
            <div class="reveal">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">{t.problemLabel}</p>
              <p class="mt-2 text-fluid-base leading-relaxed text-zinc-700 dark:text-zinc-300">{t.problem}</p>
            </div>

            <div class="reveal">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">{t.builtLabel}</p>
              <ul class="mt-3 space-y-2.5">
                {t.built.map((item) => (
                  <li class="flex items-start gap-2.5 text-sm text-zinc-700 dark:text-zinc-300">
                    <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="mt-1 flex-none text-accent-500"><polyline points="20 6 9 17 4 12" /></svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="reveal">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">{t.resultsLabel}</p>
              <ul class="mt-3 space-y-2.5">
                {t.results.map((item) => (
                  <li class="flex items-start gap-2.5 text-sm text-zinc-700 dark:text-zinc-300">
                    <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="mt-1 flex-none text-emerald-500"><path d="M20 6 9 17l-5-5" /></svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="reveal">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">{t.stackLabel}</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {t.stack.map((tech) => (
                  <span class="rounded-md border border-zinc-200 bg-zinc-100/80 px-2.5 py-1 text-[11px] font-medium text-zinc-700 dark:border-white/10 dark:bg-white/[0.04] dark:text-zinc-300">{tech}</span>
                ))}
              </div>
            </div>

            <div class="reveal flex flex-wrap items-center gap-3 pt-2">
              {waHref && (
                <a href={waHref} target="_blank" rel="noopener noreferrer" data-track="whatsapp" data-label="caso-pagina" class="inline-flex items-center gap-2 rounded-full bg-accent-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-600">
                  {t.cta}
                </a>
              )}
              <a href={siteUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white/70 px-5 py-3 text-sm font-semibold text-zinc-800 transition-colors hover:border-zinc-300 dark:border-white/15 dark:bg-white/[0.03] dark:text-zinc-100">
                {t.visit}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" /></svg>
              </a>
            </div>
          </div>

          <aside class="min-w-0 space-y-5 lg:col-span-5">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">{t.demoLabel}</p>
            <figure class="overflow-hidden rounded-2xl border border-zinc-200 bg-zinc-100 shadow-sm dark:border-white/10 dark:bg-zinc-900">
              <picture>
                <source srcset="/buho-ia-1.avif" type="image/avif" />
                <source srcset="/buho-ia-1.webp" type="image/webp" />
                <img src="/buho-ia-1.png" alt={t.beforeCaption} width="1120" height="630" loading="lazy" decoding="async" class="w-full object-cover" />
              </picture>
              <figcaption class="border-t border-zinc-200 px-4 py-2.5 text-xs text-zinc-600 dark:border-white/10 dark:text-zinc-400">{t.beforeCaption}</figcaption>
            </figure>
            <figure class="overflow-hidden rounded-2xl border border-zinc-200 bg-zinc-100 shadow-sm dark:border-white/10 dark:bg-zinc-900">
              <picture>
                <source srcset="/buho-ia-2.avif" type="image/avif" />
                <source srcset="/buho-ia-2.webp" type="image/webp" />
                <img src="/buho-ia-2.png" alt={t.afterCaption} width="1120" height="630" loading="lazy" decoding="async" class="w-full object-cover" />
              </picture>
              <figcaption class="border-t border-zinc-200 px-4 py-2.5 text-xs text-zinc-600 dark:border-white/10 dark:text-zinc-400">{t.afterCaption}</figcaption>
            </figure>
          </aside>
        </div>

        <figure class="cv-auto reveal surface mt-12 p-7 sm:p-9">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">{t.testimonialLabel}</p>
          <blockquote class="mt-4 text-fluid-base leading-relaxed text-zinc-700 dark:text-zinc-200">
            “{testimonial.quote}”
          </blockquote>
          <figcaption class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-3 border-t border-zinc-200/80 pt-5 dark:border-white/10">
            <span class="flex h-11 w-11 flex-none items-center justify-center overflow-hidden rounded-full border border-zinc-200 bg-white shadow-sm dark:border-white/10">
              <picture>
                <source srcset="/buho-logo.webp" type="image/webp" />
                <img src="/buho-logo.png" alt={testimonial.role} width="44" height="44" loading="lazy" decoding="async" class="h-full w-full object-cover" />
              </picture>
            </span>
            <div class="min-w-0 flex-1">
              <p class="font-display text-sm font-semibold text-zinc-900 dark:text-white">{testimonial.name}</p>
              <p class="text-xs leading-snug text-zinc-500">{testimonial.role}</p>
            </div>
            <span class="ml-auto flex flex-none items-center gap-1.5 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.1em] text-emerald-700 dark:text-emerald-400">
              <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
              {verifiedLabel}
            </span>
          </figcaption>
        </figure>

        <p class="mt-10">
          <a href={localeHref(locale)} class="inline-flex items-center gap-2 rounded-full border border-zinc-200 px-5 py-2.5 text-sm font-semibold text-zinc-800 transition-colors hover:bg-zinc-50 dark:border-white/15 dark:text-zinc-100 dark:hover:bg-white/[0.05]">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5" /><path d="m12 19-7-7 7-7" /></svg>
            {t.back}
          </a>
        </p>
      </div>
    </div>
  </section>
</Layout>
