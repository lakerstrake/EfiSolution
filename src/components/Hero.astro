---
import CTAButton from './react/CTAButton.tsx';

const metrics = [
  { value: '0.9s', label: 'LCP objetivo' },
  { value: '+35%', label: 'Mejora conversion' },
  { value: '100/100', label: 'Score Lighthouse' },
  { value: '48h', label: 'Auditoria inicial' },
];
---

<section id="inicio" class="relative overflow-hidden pb-24 pt-36 md:pb-28 md:pt-44" aria-labelledby="hero-title">
  <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 -z-10">
    <div class="mx-auto h-[420px] w-[820px] max-w-[120%] -translate-y-1/3 rounded-full bg-accent-500/15 blur-[120px]"></div>
  </div>

  <div class="container-x">
    <div class="mx-auto max-w-4xl text-center">
      <span class="eyebrow">
        <span class="eyebrow-dot"></span>
        Diseno y desarrollo web de alto rendimiento
      </span>

      <h1 id="hero-title" class="mt-7 font-display text-fluid-5xl font-semibold leading-[1.02] tracking-tightest text-zinc-900 dark:text-white">
        Una web mas rapida.
        <br />
        <span class="text-accent-500">Un negocio que convierte mejor.</span>
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-fluid-lg leading-relaxed text-zinc-700 dark:text-zinc-400">
        En Efi Solution construimos plataformas minimalistas, solidas y escalables para marcas que quieren crecer sin perder tiempo en tecnologia lenta.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <CTAButton client:visible href="#contacto" variant="primary" size="lg" ariaLabel="Agendar auditoria gratuita">
          Agendar auditoria gratuita
        </CTAButton>
        <CTAButton client:visible href="#casos" variant="ghost" size="lg" icon={false}>
          Ver proyectos
        </CTAButton>
      </div>

      <div class="kpi-grid mx-auto mt-14 grid-cols-2 md:grid-cols-4">
        {metrics.map((metric) => (
          <div class="kpi-item text-left">
            <p class="font-display text-fluid-2xl font-semibold text-zinc-900 dark:text-white">{metric.value}</p>
            <p class="mt-1 text-xs uppercase tracking-[0.16em] text-zinc-500">{metric.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="container-x mt-20">
    <div class="hairline"></div>
  </div>
</section>
