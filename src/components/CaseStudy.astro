---
import StatCounter from './react/StatCounter.tsx';
import { getSiteContent, type Locale } from '../i18n/siteContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getSiteContent(locale).cases;
const cases = t.items;
const imageAltPrefix: Record<Locale, string> = {
  es: 'Vista del proyecto',
  en: 'Project preview',
  pt: 'Visual do projeto',
};
---

<section id="casos" class="section-padding scroll-mt-24" aria-labelledby="cases-title">
  <div class="container-x">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow">
        <span class="eyebrow-dot"></span>
        {t.badge}
      </span>
      <h2 id="cases-title" class="mt-6 font-display text-fluid-4xl font-semibold leading-[1.06] tracking-tightest text-zinc-900 dark:text-white">
        {t.title}
      </h2>
      <p class="mt-4 text-fluid-base leading-relaxed text-zinc-700 dark:text-zinc-400">
        {t.description}
      </p>
    </div>

    <div id="cases-root" data-live-label={t.live} class="mt-10">
      <div class="flex flex-col items-center gap-4">
        <div class="flex flex-wrap justify-center gap-2" role="tablist" aria-label={t.tabLabel}>
          {cases.map((entry, index) => (
            <button
              id={`tab-${entry.key}`}
              data-tab={entry.key}
              data-index={index}
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              aria-controls={`slide-${entry.key}`}
              tabindex={index === 0 ? '0' : '-1'}
              class={`case-tab rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] transition-colors ${
                index === 0
                  ? 'active border-accent-500 bg-accent-500/10 text-accent-600 dark:text-accent-400'
                  : 'border-zinc-200 bg-white/70 text-zinc-600 hover:text-zinc-900 dark:border-white/10 dark:bg-white/[0.03] dark:text-zinc-400 dark:hover:text-white'
              }`}
            >
              {entry.name}
            </button>
          ))}
        </div>

        <div class="inline-flex items-center gap-2">
          <button
            type="button"
            data-prev
            class="rounded-full border border-zinc-200 bg-white/75 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.14em] text-zinc-600 transition-colors hover:text-zinc-900 dark:border-white/10 dark:bg-white/[0.03] dark:text-zinc-400 dark:hover:text-white"
            aria-label={t.prev}
          >
            {t.prev}
          </button>
          <button
            type="button"
            data-next
            class="rounded-full border border-zinc-200 bg-white/75 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.14em] text-zinc-600 transition-colors hover:text-zinc-900 dark:border-white/10 dark:bg-white/[0.03] dark:text-zinc-400 dark:hover:text-white"
            aria-label={t.next}
          >
            {t.next}
          </button>
        </div>

        <p id="case-live-region" class="sr-only" aria-live="polite"></p>
      </div>

      <div class="surface relative mt-8 overflow-hidden p-6 sm:p-8 lg:p-10">
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
          <div class="absolute -left-20 top-0 h-72 w-72 rounded-full bg-accent-500/10 blur-[110px]"></div>
          <div class="absolute -right-20 bottom-0 h-72 w-72 rounded-full bg-accent-500/10 blur-[110px]"></div>
        </div>

        {cases.map((entry, index) => (
          <article
            id={`slide-${entry.key}`}
            role="tabpanel"
            aria-labelledby={`tab-${entry.key}`}
            class={`case-panel grid gap-8 lg:grid-cols-12 lg:gap-10 ${index === 0 ? 'active' : 'hidden'}`}
          >
            <div class="lg:col-span-7">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">{entry.sector}</p>
              <h3 class="mt-2 font-display text-fluid-3xl font-semibold tracking-tightest text-zinc-900 dark:text-white">{entry.name}</h3>

              <p class="mt-5 text-fluid-base leading-relaxed text-zinc-700 dark:text-zinc-400">{entry.summary}</p>

              <div class="hairline my-6"></div>

              <p class="text-fluid-base leading-relaxed text-zinc-700 dark:text-zinc-300">
                <span class="font-semibold text-zinc-900 dark:text-white">{t.resultPrefix}</span> {entry.result}
              </p>

              <div class="mt-6 flex flex-wrap gap-2">
                {entry.stack.map((tech) => (
                  <span class="rounded-md border border-zinc-200 bg-zinc-100/80 px-2.5 py-1 text-[11px] font-medium text-zinc-700 dark:border-white/10 dark:bg-white/[0.04] dark:text-zinc-300">
                    {tech}
                  </span>
                ))}
              </div>

              {entry.url && (
                <a
                  href={entry.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-8 inline-flex items-center gap-2 rounded-full bg-accent-500 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-accent-600"
                >
                  {t.visit}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    <polyline points="15 3 21 3 21 9"></polyline>
                    <line x1="10" y1="14" x2="21" y2="3"></line>
                  </svg>
                </a>
              )}
            </div>

            <aside class="space-y-5 lg:col-span-5">
              <div class="overflow-hidden rounded-2xl border border-zinc-200 bg-zinc-100 shadow-sm transition-transform duration-300 hover:scale-[1.01] dark:border-white/10 dark:bg-zinc-900">
                <div class="flex items-center gap-2 border-b border-zinc-200 px-3 py-2 dark:border-white/10">
                  <span class="h-2 w-2 rounded-full bg-red-500/60"></span>
                  <span class="h-2 w-2 rounded-full bg-amber-500/60"></span>
                  <span class="h-2 w-2 rounded-full bg-emerald-500/60"></span>
                </div>
                <div class="aspect-[16/10] w-full overflow-hidden">
                  <img src={entry.image} alt={`${imageAltPrefix[locale]} ${entry.name}`} class="h-full w-full object-cover object-top" loading="lazy" />
                </div>
              </div>

              <div class="kpi-grid grid-cols-2">
                {entry.metrics.map((metric) => (
                  <div class="kpi-item">
                    <StatCounter
                      client:visible
                      value={metric.value}
                      suffix={metric.suffix}
                      label={metric.label}
                      decimals={metric.decimals ?? 0}
                    />
                  </div>
                ))}
              </div>
            </aside>
          </article>
        ))}
      </div>

      <div class="mt-4 flex justify-center gap-2" aria-hidden="true">
        {cases.map((entry, index) => (
          <span
            data-dot={entry.key}
            class={`case-dot h-1.5 w-6 rounded-full transition-all ${index === 0 ? 'bg-accent-500' : 'bg-zinc-300 dark:bg-zinc-700'}`}
          ></span>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const root = document.getElementById('cases-root') as HTMLElement | null;

  if (root && root.dataset.bound !== 'true') {
    root.dataset.bound = 'true';

    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('.case-tab'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('.case-panel'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('.case-dot'));
    const prevButton = root.querySelector<HTMLButtonElement>('[data-prev]');
    const nextButton = root.querySelector<HTMLButtonElement>('[data-next]');
    const liveRegion = root.querySelector<HTMLElement>('#case-live-region');
    const liveLabel = root.dataset.liveLabel ?? 'Active case';

    let activeIndex = tabs.findIndex((tab) => tab.getAttribute('aria-selected') === 'true');
    let timerId: number | null = null;

    function syncDots() {
      dots.forEach((dot, index) => {
        dot.classList.toggle('bg-accent-500', index === activeIndex);
        dot.classList.toggle('bg-zinc-300', index !== activeIndex);
        dot.classList.toggle('dark:bg-zinc-700', index !== activeIndex);
      });
    }

    function activateCase(nextIndex: number, moveFocus = false): void {
      activeIndex = (nextIndex + tabs.length) % tabs.length;

      tabs.forEach((tab, index) => {
        const isActive = index === activeIndex;
        tab.classList.toggle('active', isActive);
        tab.classList.toggle('border-accent-500', isActive);
        tab.classList.toggle('bg-accent-500/10', isActive);
        tab.classList.toggle('text-accent-600', isActive);
        tab.classList.toggle('dark:text-accent-400', isActive);
        tab.setAttribute('aria-selected', String(isActive));
        tab.setAttribute('tabindex', isActive ? '0' : '-1');
        if (moveFocus && isActive) tab.focus();
      });

      panels.forEach((panel, index) => {
        const isActive = index === activeIndex;
        panel.classList.toggle('hidden', !isActive);
        panel.classList.toggle('active', isActive);
        if (isActive) {
          panel.classList.remove('animate-fade-up');
          void panel.offsetWidth;
          panel.classList.add('animate-fade-up');
        }
      });

      syncDots();
      if (liveRegion) {
        liveRegion.textContent = `${liveLabel}: ${tabs[activeIndex]?.textContent?.trim() ?? ''}`;
      }
    }

    function startAutoRotate() {
      if (timerId) window.clearInterval(timerId);
      timerId = window.setInterval(() => activateCase(activeIndex + 1), 9000);
    }

    function stopAutoRotate() {
      if (timerId) {
        window.clearInterval(timerId);
        timerId = null;
      }
    }

    tabs.forEach((tab, index) => {
      tab.addEventListener('click', () => {
        activateCase(index);
        startAutoRotate();
      });

      tab.addEventListener('keydown', (event: KeyboardEvent) => {
        if (event.key === 'ArrowRight') {
          event.preventDefault();
          activateCase(index + 1, true);
          startAutoRotate();
        }
        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          activateCase(index - 1, true);
          startAutoRotate();
        }
      });
    });

    prevButton?.addEventListener('click', () => {
      activateCase(activeIndex - 1);
      startAutoRotate();
    });

    nextButton?.addEventListener('click', () => {
      activateCase(activeIndex + 1);
      startAutoRotate();
    });

    root.addEventListener('mouseenter', stopAutoRotate);
    root.addEventListener('mouseleave', startAutoRotate);
    root.addEventListener('focusin', stopAutoRotate);
    root.addEventListener('focusout', startAutoRotate);

    activateCase(activeIndex < 0 ? 0 : activeIndex);
    startAutoRotate();
  }
</script>
