---
import StatCounter from './react/StatCounter.tsx';

const metrics = [
  { value: 92, suffix: '%', label: 'Reducción de tiempo de carga' },
  { value: 4.7, decimals: 1, suffix: 'x', label: 'Más solicitudes diarias' },
  { value: 100, suffix: '/100', label: 'Lighthouse en producción' },
  { value: 0, suffix: '', label: 'Tiempo de inactividad' },
];

const stack = ['Astro', 'TypeScript', 'FastAPI', 'PostgreSQL', 'Tailwind', 'Cloudflare'];
---

<section
  id="caso-classify"
  class="section-padding relative"
  aria-labelledby="case-title"
>
  <div class="container-x">
    <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-b from-white/[0.03] to-transparent">
      <!-- Decorative glow inside the case study card -->
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
        <div class="absolute -left-32 top-0 h-80 w-80 rounded-full bg-accent-500/15 blur-[120px]"></div>
        <div class="absolute -right-24 bottom-0 h-80 w-80 rounded-full bg-accent-500/10 blur-[120px]"></div>
      </div>

      <div class="grid gap-10 p-7 sm:p-10 md:gap-14 md:p-14 lg:grid-cols-12 lg:gap-16">
        <!-- Left: narrative -->
        <div class="lg:col-span-7">
          <div class="flex flex-wrap items-center gap-3">
            <span class="eyebrow">
              <span class="eyebrow-dot"></span>
              Caso de éxito
            </span>
            <span class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1 text-[11px] tracking-widest text-zinc-400 uppercase">
              Edtech · Colombia
            </span>
          </div>

          <div class="mt-6 flex items-center gap-4">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl border border-white/10 bg-white/[0.04]">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="text-accent-300">
                <path d="M22 10v6M2 10l10-5 10 5-10 5z" />
                <path d="M6 12v5c3 3 9 3 12 0v-5" />
              </svg>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.18em] text-zinc-500">Cliente</p>
              <h3 id="case-title" class="font-display text-fluid-3xl font-semibold tracking-tightest text-white">
                Classify <span class="text-accent-400">·</span> Gestión Escolar
              </h3>
            </div>
          </div>

          <!-- Story blocks -->
          <div class="mt-10 space-y-8">
            <div>
              <p class="text-xs uppercase tracking-[0.22em] text-zinc-500">El Problema</p>
              <p class="mt-3 text-fluid-base leading-relaxed text-zinc-300">
                Classify operaba sobre un panel WordPress saturado de plugins. Cargaba en
                <span class="text-white">5.4 segundos</span> en celular, perdía padres de familia
                en pleno proceso de inscripción y el equipo administrativo necesitaba un
                respaldo manual cada semana.
              </p>
            </div>

            <div class="hairline"></div>

            <div>
              <p class="text-xs uppercase tracking-[0.22em] text-zinc-500">Nuestra Solución</p>
              <p class="mt-3 text-fluid-base leading-relaxed text-zinc-300">
                Reescribimos la plataforma desde cero con <span class="text-white">arquitectura island</span>
                en Astro, un backend en <span class="text-white">FastAPI</span> con tareas asíncronas,
                base de datos PostgreSQL y entrega global por edge CDN. El panel se rediseñó
                con Sarai bajo un sistema de UX basado en pruebas reales con profesores y padres.
              </p>

              <div class="mt-5 flex flex-wrap gap-2">
                {stack.map((t) => (
                  <span class="rounded-md border border-white/10 bg-white/[0.025] px-2.5 py-1 font-mono text-[11px] tracking-tight text-zinc-300">
                    {t}
                  </span>
                ))}
              </div>
            </div>

            <div class="hairline"></div>

            <div>
              <p class="text-xs uppercase tracking-[0.22em] text-accent-400">El Resultado</p>
              <p class="mt-3 text-fluid-base leading-relaxed text-zinc-300">
                En el primer trimestre, las inscripciones digitales se cuadruplicaron, el
                tiempo de carga bajó a <span class="text-white">0.4 segundos</span>, y el
                equipo redujo el trabajo administrativo en un <span class="text-white">70%</span>.
              </p>
            </div>

            <!-- Testimonial -->
            <figure class="relative mt-2 rounded-2xl border border-white/10 bg-white/[0.025] p-6 sm:p-7">
              <svg aria-hidden="true" class="absolute -top-3 left-6 h-6 w-6 text-accent-400/70" viewBox="0 0 24 24" fill="currentColor">
                <path d="M9 7H5a2 2 0 00-2 2v4a2 2 0 002 2h2v4H3v2h6v-8H7V9h2zm10 0h-4a2 2 0 00-2 2v4a2 2 0 002 2h2v4h-4v2h6v-8h-2V9h2z" />
              </svg>
              <blockquote class="text-fluid-base leading-relaxed text-zinc-200">
                “Pensábamos contratar a dos personas más para atender solicitudes. Después
                del rediseño, ese mismo equipo procesa cuatro veces más inscripciones sin
                horas extra. Efi Solution no entregó una web: nos entregó un sistema.”
              </blockquote>
              <figcaption class="mt-5 flex items-center gap-3 text-sm">
                <span class="flex h-9 w-9 items-center justify-center rounded-full border border-white/10 bg-white/[0.05] font-display text-xs font-semibold text-white">
                  CR
                </span>
                <div>
                  <p class="font-medium text-zinc-100">Carlos Rivera</p>
                  <p class="text-xs text-zinc-500">Director · Classify</p>
                </div>
              </figcaption>
            </figure>
          </div>
        </div>

        <!-- Right: stats -->
        <aside class="lg:col-span-5">
          <div class="sticky top-28 rounded-2xl border border-white/10 bg-zinc-950/40 p-7 backdrop-blur-md">
            <p class="text-xs uppercase tracking-[0.22em] text-zinc-500">Impacto medible</p>
            <div class="mt-6 grid grid-cols-2 gap-x-6 gap-y-8">
              {metrics.map((m) => (
                <StatCounter
                  client:visible
                  value={m.value}
                  suffix={m.suffix}
                  decimals={m.decimals ?? 0}
                  label={m.label}
                />
              ))}
            </div>

            <div class="mt-8 hairline"></div>

            <!-- Mini "before / after" stat -->
            <div class="mt-8 grid grid-cols-2 gap-4">
              <div class="rounded-xl border border-white/10 bg-white/[0.02] p-4">
                <p class="text-[11px] uppercase tracking-[0.18em] text-zinc-500">Antes</p>
                <p class="mt-2 font-display text-2xl font-semibold text-zinc-400 line-through decoration-zinc-700">
                  5.4s
                </p>
                <p class="mt-1 text-xs text-zinc-500">Tiempo de carga (móvil)</p>
              </div>
              <div class="rounded-xl border border-accent-500/30 bg-accent-500/[0.06] p-4 shadow-glow-accent">
                <p class="text-[11px] uppercase tracking-[0.18em] text-accent-300">Después</p>
                <p class="mt-2 font-display text-2xl font-semibold text-white">0.4s</p>
                <p class="mt-1 text-xs text-zinc-400">Tiempo de carga (móvil)</p>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>
</section>
