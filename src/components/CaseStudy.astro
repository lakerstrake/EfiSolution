<script>
  // ── Tab selection switcher ───────────────────────────────────────────────
  const tabs = document.querySelectorAll('.case-study-tab');
  const slides = document.querySelectorAll('.case-study-slide');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      // Remove active and update ARIA states
      tabs.forEach((t) => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');

      const tabName = (tab as HTMLElement).dataset.tab;
      const targetId = `slide-${tabName}`;

      slides.forEach((slide) => {
        slide.classList.remove('active');
      });

      const activeSlide = document.getElementById(targetId);
      if (activeSlide) {
        activeSlide.classList.add('active');
      }
    });
  });

  // ── Dispatch window event to trigger React previewer modal ───────────────
  const previewButtons = document.querySelectorAll('.live-preview-trigger');
  
  previewButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const url = (btn as HTMLElement).dataset.url;
      const title = (btn as HTMLElement).dataset.title;
      
      if (url && title) {
        window.dispatchEvent(
          new CustomEvent('open-preview', {
            detail: { url, title },
          })
        );
      }
    });
  });
</script>
