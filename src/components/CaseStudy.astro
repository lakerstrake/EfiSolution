---
import { getSiteContent, type Locale } from '../i18n/siteContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getSiteContent(locale).cases;
const cases = t.items;
const imageAltPrefix: Record<Locale, string> = {
  es: 'Vista del proyecto',
  en: 'Project preview',
  pt: 'Visual do projeto',
  fr: 'Apercu du projet',
};
const formatMetric = (value: number, decimals = 0) => value.toFixed(decimals);
---

<section id="casos" class="cv-auto section-padding" aria-labelledby="cases-title">
  <div class="container-x">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow">
        <span class="eyebrow-dot"></span>
        {t.badge}
      </span>
      <h2 id="cases-title" class="mt-6 font-display text-fluid-4xl font-semibold leading-[1.06] tracking-tightest text-zinc-900 dark:text-white">
        {t.title}
      </h2>
      <p class="mt-4 text-fluid-base leading-relaxed text-zinc-700 dark:text-zinc-400">
        {t.description}
      </p>
    </div>

    <div id="cases-root" data-live-label={t.live} class="reveal mt-10">
      <div class="flex flex-col items-center gap-4">
        <div class="flex flex-wrap justify-center gap-2" role="tablist" aria-label={t.tabLabel}>
          {cases.map((entry, index) => (
            <button
              id={`tab-${entry.key}`}
              data-tab={entry.key}
              data-index={index}
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              aria-controls={`slide-${entry.key}`}
              tabindex={index === 0 ? '0' : '-1'}
              class={`case-tab rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] transition-all duration-200 ${
                index === 0
                  ? 'active border-accent-500 bg-accent-500/10 text-accent-600 dark:text-accent-400'
                  : 'border-zinc-200 bg-white/70 text-zinc-600 hover:text-zinc-900 dark:border-white/10 dark:bg-white/[0.03] dark:text-zinc-400 dark:hover:text-white'
              }`}
            >
              {entry.name}
            </button>
          ))}
        </div>

        <div class="inline-flex items-center gap-2">
          <button
            type="button"
            data-prev
            class="rounded-full border border-zinc-200 bg-white/75 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.14em] text-zinc-600 transition-colors hover:text-zinc-900 dark:border-white/10 dark:bg-white/[0.03] dark:text-zinc-400 dark:hover:text-white"
            aria-label={t.prev}
          >
            {t.prev}
          </button>
          <button
            type="button"
            data-next
            class="rounded-full border border-zinc-200 bg-white/75 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.14em] text-zinc-600 transition-colors hover:text-zinc-900 dark:border-white/10 dark:bg-white/[0.03] dark:text-zinc-400 dark:hover:text-white"
            aria-label={t.next}
          >
            {t.next}
          </button>
        </div>

        <p id="case-live-region" class="sr-only" aria-live="polite"></p>
      </div>

      <div class="surface relative mt-8 overflow-hidden p-6 sm:p-8 lg:p-10">
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
          <div class="absolute -left-20 top-0 h-72 w-72 rounded-full bg-accent-500/10 blur-[110px]"></div>
          <div class="absolute -right-20 bottom-0 h-72 w-72 rounded-full bg-accent-500/10 blur-[110px]"></div>
        </div>

        {cases.map((entry, index) => {
          const Media = entry.url ? 'a' : 'div';
          const mediaProps = entry.url
            ? { href: entry.url, target: '_blank', rel: 'noopener noreferrer', 'aria-label': `${t.visit}: ${entry.name}` }
            : {};
          const imgBase = entry.image.replace(/\.[a-z0-9]+$/i, '');
          // SVG placeholders no tienen variantes avif/webp: evita 404 saltando los <source>.
          const hasRaster = !/\.svg$/i.test(entry.image);
          return (
          <div
            id={`slide-${entry.key}`}
            role="tabpanel"
            aria-labelledby={`tab-${entry.key}`}
            class={`case-panel grid gap-8 lg:grid-cols-12 lg:gap-10 ${index === 0 ? 'active' : 'hidden'}`}
          >
            <div class="min-w-0 lg:col-span-7">
              <div class="flex flex-wrap items-center gap-2">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">{entry.sector}</p>
                <span class="rounded-full border border-accent-500/30 bg-accent-500/10 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-[0.14em] text-accent-600 dark:text-accent-400">{entry.tag}</span>
              </div>
              <h3 class="mt-2 font-display text-fluid-3xl font-semibold tracking-tightest text-zinc-900 dark:text-white">{entry.name}</h3>

              <p class="mt-5 text-fluid-base leading-relaxed text-zinc-700 dark:text-zinc-400">{entry.summary}</p>

              <div class="hairline my-6"></div>

              <p class="text-fluid-base leading-relaxed text-zinc-700 dark:text-zinc-300">
                <span class="font-semibold text-zinc-900 dark:text-white">{t.resultPrefix}</span> {entry.result}
              </p>

              <div class="mt-6 flex flex-wrap gap-2">
                {entry.stack.map((tech) => (
                  <span class="rounded-md border border-zinc-200 bg-zinc-100/80 px-2.5 py-1 text-[11px] font-medium text-zinc-700 dark:border-white/10 dark:bg-white/[0.04] dark:text-zinc-300">
                    {tech}
                  </span>
                ))}
              </div>

              {entry.url && (
                <a
                  href={entry.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-8 inline-flex items-center gap-2 rounded-full bg-accent-500 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-accent-600"
                >
                  {t.visit}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                    <polyline points="15 3 21 3 21 9"></polyline>
                    <line x1="10" y1="14" x2="21" y2="3"></line>
                  </svg>
                </a>
              )}
            </div>

            <aside class="min-w-0 space-y-5 lg:col-span-5">
              <Media
                {...mediaProps}
                class="group/media relative block overflow-hidden rounded-2xl border border-zinc-200 bg-zinc-100 shadow-sm transition-transform duration-300 hover:scale-[1.01] focus-visible:scale-[1.01] dark:border-white/10 dark:bg-zinc-900"
              >
                <div class="flex items-center gap-2 border-b border-zinc-200 px-3 py-2 dark:border-white/10">
                  <span class="h-2 w-2 rounded-full bg-red-500/60"></span>
                  <span class="h-2 w-2 rounded-full bg-amber-500/60"></span>
                  <span class="h-2 w-2 rounded-full bg-emerald-500/60"></span>
                </div>
                <div class="relative aspect-[16/10] w-full overflow-hidden">
                  <picture>
                    {hasRaster && <source srcset={`${imgBase}.avif`} type="image/avif" />}
                    {hasRaster && <source srcset={`${imgBase}.webp`} type="image/webp" />}
                    <img
                      src={entry.image}
                      alt={`${imageAltPrefix[locale]} ${entry.name}`}
                      class="h-full w-full object-cover object-top"
                      width="800"
                      height="500"
                      loading={index === 0 ? 'eager' : 'lazy'}
                      decoding={index === 0 ? 'sync' : 'async'}
                      fetchpriority={index === 0 ? 'high' : 'auto'}
                    />
                  </picture>
                  {entry.url && (
                    <span
                      aria-hidden="true"
                      class="pointer-events-none absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-300 group-hover/media:opacity-100 group-focus-visible/media:opacity-100"
                    >
                      <span class="absolute inset-0 bg-zinc-950/30"></span>
                      <span class="relative inline-flex items-center gap-2 rounded-full bg-white/95 px-4 py-2 text-xs font-semibold text-zinc-900 shadow-lg">
                        {t.visit}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                          <polyline points="15 3 21 3 21 9"></polyline>
                          <line x1="10" y1="14" x2="21" y2="3"></line>
                        </svg>
                      </span>
                    </span>
                  )}
                </div>
              </Media>

              <div class="kpi-grid grid-cols-2">
                {entry.metrics.map((metric, mi) => {
                  // With an odd number of metrics, let the last tile span the full
                  // width so the grid never leaves a hollow cell showing the divider.
                  const spanFull = entry.metrics.length % 2 === 1 && mi === entry.metrics.length - 1;
                  return (
                  <div class={`kpi-item ${spanFull ? 'col-span-2' : ''}`}>
                    <div class={`flex flex-col ${spanFull ? 'sm:flex-row sm:items-baseline sm:justify-between sm:gap-3' : ''}`}>
                      <p class="font-display text-fluid-3xl font-semibold tracking-tightest text-zinc-900 dark:text-white">
                        {formatMetric(metric.value, metric.decimals ?? 0)}{metric.suffix}
                      </p>
                      <p class={`text-xs uppercase tracking-[0.16em] text-zinc-500 ${spanFull ? 'mt-1 sm:mt-0' : 'mt-2'}`}>{metric.label}</p>
                    </div>
                  </div>
                  );
                })}
              </div>
            </aside>
          </div>
          );
        })}
      </div>

      <div class="mt-4 flex justify-center gap-2" aria-hidden="true">
        {cases.map((entry, index) => (
          <span
            data-dot={entry.key}
            class={`case-dot h-1.5 w-6 rounded-full transition-all ${index === 0 ? 'bg-accent-500' : 'bg-zinc-300 dark:bg-zinc-700'}`}
          ></span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .case-tab[aria-selected='true'] {
    background-color: rgba(11, 84, 253, 0.14);
    border-color: rgba(11, 84, 253, 0.65);
    color: rgb(11, 84, 253);
    box-shadow: 0 0 0 1px rgba(11, 84, 253, 0.15) inset;
  }
  .dark .case-tab[aria-selected='true'] {
    color: rgb(147, 197, 253);
    border-color: rgba(147, 197, 253, 0.5);
    background-color: rgba(11, 84, 253, 0.25);
  }
</style>

<script>
  let _caseCtrl: AbortController | null = null;

  function initCases(): void {
    const root = document.getElementById('cases-root') as HTMLElement | null;
    if (!root) return;

    _caseCtrl?.abort();
    _caseCtrl = new AbortController();
    const { signal } = _caseCtrl;

    const tabs      = Array.from(root.querySelectorAll<HTMLButtonElement>('.case-tab'));
    const panels    = Array.from(root.querySelectorAll<HTMLElement>('.case-panel'));
    const dots      = Array.from(root.querySelectorAll<HTMLElement>('.case-dot'));
    const prevBtn   = root.querySelector<HTMLButtonElement>('[data-prev]');
    const nextBtn   = root.querySelector<HTMLButtonElement>('[data-next]');
    const liveRegion = root.querySelector<HTMLElement>('#case-live-region');
    const liveLabel = root.dataset.liveLabel ?? 'Active case';

    let activeIndex = Math.max(0, tabs.findIndex((t) => t.getAttribute('aria-selected') === 'true'));
    let timerId: number | null = null;

    function syncDots(): void {
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-accent-500', i === activeIndex);
        dot.classList.toggle('bg-zinc-300',   i !== activeIndex);
        dot.classList.toggle('dark:bg-zinc-700', i !== activeIndex);
      });
    }

    function activateCase(next: number, moveFocus = false): void {
      activeIndex = ((next % tabs.length) + tabs.length) % tabs.length;

      tabs.forEach((tab, i) => {
        const active = i === activeIndex;
        tab.classList.toggle('active',           active);
        tab.classList.toggle('border-accent-500', active);
        tab.classList.toggle('bg-accent-500/10', active);
        tab.classList.toggle('text-accent-600',  active);
        tab.classList.toggle('dark:text-accent-400', active);
        tab.setAttribute('aria-selected', String(active));
        tab.setAttribute('tabindex', active ? '0' : '-1');
        if (moveFocus && active) tab.focus();
      });

      panels.forEach((panel, i) => {
        const active = i === activeIndex;
        panel.classList.toggle('hidden', !active);
        panel.classList.toggle('active', active);
        if (active) {
          panel.classList.remove('animate-fade-up');
          void panel.offsetWidth;
          panel.classList.add('animate-fade-up');
        }
      });

      syncDots();
      if (liveRegion) {
        liveRegion.textContent = `${liveLabel}: ${tabs[activeIndex]?.textContent?.trim() ?? ''}`;
      }
    }

    function startAutoRotate(): void {
      if (timerId) window.clearInterval(timerId);
      timerId = window.setInterval(() => activateCase(activeIndex + 1), 12000);
    }

    function stopAutoRotate(): void {
      if (timerId) { window.clearInterval(timerId); timerId = null; }
    }

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => { activateCase(i); startAutoRotate(); }, { signal });
      tab.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'ArrowRight') { e.preventDefault(); activateCase(i + 1, true); startAutoRotate(); }
        if (e.key === 'ArrowLeft')  { e.preventDefault(); activateCase(i - 1, true); startAutoRotate(); }
      }, { signal });
    });

    prevBtn?.addEventListener('click', () => { activateCase(activeIndex - 1); startAutoRotate(); }, { signal });
    nextBtn?.addEventListener('click', () => { activateCase(activeIndex + 1); startAutoRotate(); }, { signal });

    root.addEventListener('mouseenter', stopAutoRotate, { signal });
    root.addEventListener('mouseleave', startAutoRotate, { signal });
    root.addEventListener('focusin',    stopAutoRotate,  { signal });
    root.addEventListener('focusout',   (e: FocusEvent) => {
      const next = e.relatedTarget as Node | null;
      if (!next || !root.contains(next)) startAutoRotate();
    }, { signal });

    document.addEventListener('visibilitychange', () => {
      document.hidden ? stopAutoRotate() : startAutoRotate();
    }, { signal });

    activateCase(activeIndex);
    startAutoRotate();

    // Warm the other (lazy, hidden-panel) case images during idle time so that
    // switching tabs is instant instead of waiting for a fetch on first reveal.
    const warmImages = () => {
      // Flip hidden lazy images to eager so the browser fetches them now (and
      // picks the right <picture> source: AVIF/WebP), making tab switches instant.
      root.querySelectorAll<HTMLImageElement>('img[loading="lazy"]').forEach((img) => {
        img.loading = 'eager';
      });
    };
    const ric = (window as unknown as {
      requestIdleCallback?: (cb: () => void, opts?: { timeout: number }) => void;
    }).requestIdleCallback;
    if (ric) ric(warmImages, { timeout: 2500 });
    else window.setTimeout(warmImages, 1800);
  }

  document.addEventListener('astro:page-load', initCases);
</script>
