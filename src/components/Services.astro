---
import ServiceCard from './ServiceCard.astro';
import { getSiteContent, type Locale } from '../i18n/siteContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getSiteContent(locale).services;
---

<section id="servicios" class="section-padding" aria-labelledby="services-title">
  <div class="container-x">
    <div class="reveal flex flex-col items-start gap-5 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <span class="eyebrow">
          <span class="eyebrow-dot"></span>
          {t.badge}
        </span>
        <h2 id="services-title" class="mt-5 font-display text-fluid-4xl font-semibold leading-[1.06] tracking-tightest text-zinc-900 dark:text-white">
          {t.title}
        </h2>
      </div>
      <p class="max-w-sm text-fluid-base leading-relaxed text-zinc-600 dark:text-zinc-400">
        {t.description}
      </p>
    </div>

    <ul class="mt-10 grid list-none gap-5 sm:grid-cols-2 lg:grid-cols-4" aria-label={t.listLabel}>
      {t.services.map((service, index) => (
        <li class="flex">
          <ServiceCard
            index={index}
            number={service.number}
            title={service.title}
            description={service.description}
            bullets={service.bullets}
            iconPath={service.iconPath}
          />
        </li>
      ))}
    </ul>

    <ol class="reveal kpi-grid mt-10 grid-cols-2 md:grid-cols-4" aria-label={t.processLabel}>
      {t.steps.map((step) => (
        <li class="kpi-item flex items-center justify-between">
          <div class="pr-3">
            <p class="font-mono text-xs text-zinc-500">{step.k}</p>
            <p class="mt-1 text-sm font-semibold text-zinc-900 dark:text-zinc-100">{step.v}</p>
            <p class="mt-1 text-[11px] leading-relaxed text-zinc-500 dark:text-zinc-400">{step.desc}</p>
          </div>
          <p class="shrink-0 text-xs text-zinc-500">{step.d}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
