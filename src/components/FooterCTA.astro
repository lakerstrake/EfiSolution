---
import CTAButton from './CTAButton.astro';
import pkg from '../../package.json';
import { getSiteContent, type Locale } from '../i18n/siteContent';
import { SITE, WEB3FORMS_ACCESS_KEY } from '../config/site';
import { privacyRoute, privacyLabel } from '../i18n/legal';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getSiteContent(locale);
const { version } = pkg;
const contactEmail = SITE.email;

const mailSubjects: Record<Locale, string> = {
  es: 'Solicitud%20de%20Auditoria%20Web%20-%20Efi%20Solution',
  en: 'Web%20Audit%20Request%20-%20Efi%20Solution',
  pt: 'Solicitacao%20de%20Auditoria%20Web%20-%20Efi%20Solution',
  fr: 'Demande%20d%27audit%20web%20-%20Efi%20Solution',
};
// Standard mailto so the CTA opens the visitor's own mail client (Gmail app,
// Outlook, Apple Mail...) instead of forcing the Gmail web compose window.
const mailHref = `mailto:${contactEmail}?subject=${mailSubjects[locale]}`;

const f = t.contact.form;
const whatsappHref = SITE.whatsapp
  ? `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(f.whatsappMessage)}`
  : null;

const inputClass =
  'w-full rounded-xl border border-zinc-200 bg-white/70 px-4 py-3 text-sm text-zinc-900 outline-none transition-colors placeholder:text-zinc-400 focus:border-accent-500 focus:ring-2 focus:ring-accent-500/30 dark:border-white/10 dark:bg-white/[0.04] dark:text-white dark:placeholder:text-zinc-500';
const whatsappClass =
  'inline-flex items-center justify-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-5 py-3 text-sm font-semibold text-emerald-700 transition-colors hover:bg-emerald-500/20 dark:text-emerald-400';

const privacyHref = privacyRoute[locale];

function formatBogotaDate(dateLike: string | Date): string {
  return new Intl.DateTimeFormat(t.footer.dateLocale, {
    timeZone: 'America/Bogota',
    year: 'numeric',
    month: 'short',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
  }).format(new Date(dateLike));
}

const syncSha = (process.env.CF_PAGES_COMMIT_SHA ?? process.env.GITHUB_SHA ?? 'local').slice(0, 12);
const syncTimestamp = process.env.CF_PAGES_COMMIT_TIMESTAMP ?? new Date().toISOString();
const syncDate = formatBogotaDate(syncTimestamp);
---

<section id="contacto" class="cv-auto section-padding" aria-labelledby="cta-title">
  <div class="container-x">
    <div class="reveal surface relative overflow-hidden p-8 sm:p-12">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
        <div class="absolute left-1/2 top-0 h-72 w-[580px] -translate-x-1/2 -translate-y-1/3 rounded-full bg-accent-500/15 blur-[110px]"></div>
      </div>

      <div class="grid gap-10 lg:grid-cols-12 lg:gap-14">
        <div class="min-w-0 lg:col-span-7">
          <span class="eyebrow">
            <span class="eyebrow-dot"></span>
            {t.contact.badge}
          </span>

          <h2 id="cta-title" class="mt-6 font-display text-fluid-4xl font-semibold leading-[1.04] tracking-tightest text-zinc-900 dark:text-white">
            {t.contact.titleA}
            <br />
            {t.contact.titleB}
          </h2>

          <p class="mt-6 max-w-xl text-fluid-lg leading-relaxed text-zinc-700 dark:text-zinc-400">
            {t.contact.description}
          </p>

          {WEB3FORMS_ACCESS_KEY ? (
            <form id="contact-form" class="mt-8 space-y-4" novalidate>
              <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
              <input type="hidden" name="subject" value="Nuevo lead — sitio Efi Solution" />
              <input type="hidden" name="from_name" value="Efi Solution Web" />
              {/* Contexto del lead: idioma, sección de origen y URL exacta. Llegan
                  en el correo para saber de dónde viene cada contacto. */}
              <input type="hidden" name="lead_origin" value="Formulario de contacto (web)" />
              <input type="hidden" name="locale" value={locale} />
              <input type="hidden" name="page_url" id="cf-page-url" value="" />
              <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />

              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label for="cf-name" class="mb-1.5 block text-xs font-medium text-zinc-600 dark:text-zinc-400">{f.name}</label>
                  <input id="cf-name" name="name" type="text" required autocomplete="name" placeholder={f.namePh} class={inputClass} />
                </div>
                <div>
                  <label for="cf-email" class="mb-1.5 block text-xs font-medium text-zinc-600 dark:text-zinc-400">{f.email}</label>
                  <input id="cf-email" name="email" type="email" required autocomplete="email" placeholder={f.emailPh} class={inputClass} />
                </div>
              </div>

              <div>
                <label for="cf-message" class="mb-1.5 block text-xs font-medium text-zinc-600 dark:text-zinc-400">{f.message}</label>
                <textarea id="cf-message" name="message" required rows="4" placeholder={f.messagePh} class={inputClass}></textarea>
              </div>

              <label class="flex items-start gap-2 text-xs leading-relaxed text-zinc-600 dark:text-zinc-400">
                <input type="checkbox" name="consent" value="yes" required class="mt-0.5 h-4 w-4 shrink-0 rounded border-zinc-300 accent-accent-500 dark:border-white/20" />
                <span>{f.consent} <a href={privacyHref} class="font-medium text-accent-600 underline underline-offset-2 hover:text-accent-700 dark:text-accent-400">{privacyLabel[locale]}</a>.</span>
              </label>

              <div class="flex flex-wrap items-center gap-3 pt-1">
                <button
                  type="submit"
                  data-send-label={f.send}
                  data-sending-label={f.sending}
                  class="inline-flex items-center justify-center gap-2 rounded-full bg-accent-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-600 disabled:cursor-not-allowed disabled:opacity-60 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-200"
                >
                  {f.send}
                </button>

                {whatsappHref && (
                  <a href={whatsappHref} target="_blank" rel="noopener noreferrer" data-track="whatsapp" data-label="contacto" class={whatsappClass}>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.002-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                    {f.whatsapp}
                  </a>
                )}
              </div>

              <p
                data-form-status
                role="status"
                aria-live="polite"
                data-success={f.success}
                data-error={f.error}
                class="hidden text-sm font-medium"
              ></p>

              {whatsappHref && (
                <a
                  data-form-fallback
                  hidden
                  href={whatsappHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-track="whatsapp"
                  data-label="contacto"
                  class="inline-flex items-center gap-1.5 text-sm font-semibold text-emerald-600 underline underline-offset-4 transition-colors hover:text-emerald-700 dark:text-emerald-400 dark:hover:text-emerald-300"
                >
                  {f.errorWa}
                </a>
              )}
            </form>
          ) : (
            <div class="mt-9 flex flex-wrap items-center gap-3">
              <CTAButton href={mailHref} variant="primary" size="lg" ariaLabel={t.contact.ctaAria}>
                {t.contact.cta}
              </CTAButton>

              {whatsappHref && (
                <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class={whatsappClass}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.002-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                  {f.whatsapp}
                </a>
              )}
            </div>
          )}

          <ul class="mt-7 flex flex-wrap gap-x-5 gap-y-2 text-sm text-zinc-600 dark:text-zinc-400" aria-label={t.contact.benefitsLabel}>
            {t.contact.benefits.map((benefit) => (
              <li class="inline-flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-accent-500"></span>{benefit}</li>
            ))}
          </ul>
        </div>

        <div class="min-w-0 space-y-4 lg:col-span-5">
          {t.contact.team.map((person) => (
            <article class="rounded-2xl border border-zinc-200/80 bg-white/65 p-5 dark:border-white/10 dark:bg-white/[0.04]" aria-label={`${person.name} - ${person.role}`}>
              <div class="flex items-center gap-3">
                <span class="flex h-11 w-11 items-center justify-center rounded-xl border border-zinc-200 bg-zinc-100 font-display text-xs font-semibold text-zinc-800 dark:border-white/10 dark:bg-zinc-900 dark:text-zinc-200">{person.initials}</span>
                <div>
                  <p class="font-display text-base font-semibold text-zinc-900 dark:text-white">{person.name}</p>
                  <p class="text-xs uppercase tracking-[0.16em] text-zinc-500">{person.role}</p>
                </div>
              </div>
              <p class="mt-3 text-sm leading-relaxed text-zinc-700 dark:text-zinc-400">{person.bio}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="container-x" aria-label={t.footer.siteInfo}>
  <div class="mt-10 flex flex-col items-center justify-between gap-3 border-t border-zinc-200/80 pb-10 pt-6 text-xs text-zinc-500 dark:border-white/10">
    <p class="text-center">&copy; {new Date().getFullYear()} Efi Solution. {t.footer.madeIn}</p>

    <div class="flex items-center gap-3">
      <a
        href="https://github.com/lakerstrake"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="transition-colors hover:text-zinc-900 dark:hover:text-white"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.021c0 4.428 2.865 8.185 6.839 9.504.5.092.682-.217.682-.482 0-.237-.009-.868-.014-1.703-2.782.605-3.369-1.342-3.369-1.342-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.203 22 16.447 22 12.021 22 6.484 17.523 2 12 2z"/>
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/juanmlagosm/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="transition-colors hover:text-zinc-900 dark:hover:text-white"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a
        href={mailHref}
        class="transition-colors hover:text-zinc-900 dark:hover:text-white"
      >{contactEmail}</a>
    </div>

    {/* Metadatos de desarrollo: solo en `astro dev`, nunca en producción. */}
    {import.meta.env.DEV && (
      <p class="inline-flex flex-wrap items-center justify-center gap-2 text-center">
        <span class="rounded-full border border-emerald-500/25 bg-emerald-500/10 px-2 py-0.5 font-mono text-[10px] font-semibold text-emerald-600 dark:text-emerald-400">v{version}</span>
        <span class="rounded-full border border-zinc-200 px-2 py-0.5 font-mono text-[10px] dark:border-white/15">
          {t.footer.syncLabel}: {syncDate} {t.footer.timezone}
        </span>
        <span class="rounded-full border border-zinc-200 px-2 py-0.5 font-mono text-[10px] dark:border-white/15">
          {t.footer.commitLabel}: {syncSha}
        </span>
      </p>
    )}

    <p class="text-center">
      <a
        href={privacyHref}
        class="text-xs text-zinc-500 underline underline-offset-2 transition-colors hover:text-zinc-800 dark:hover:text-zinc-300"
      >{privacyLabel[locale]}</a>
    </p>
  </div>
</footer>

<script>
  function initContactForm(): void {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form) return;

    const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const status = form.querySelector<HTMLElement>('[data-form-status]');
    if (!btn || !status) return;

    // Stamp the exact page URL so each lead's email shows where it came from.
    const urlField = form.querySelector<HTMLInputElement>('#cf-page-url');
    if (urlField) urlField.value = location.href;

    // To migrate from Web3Forms to your own Cloudflare Worker, change this one
    // line to your Worker URL (see workers/lead-worker.js).
    const ENDPOINT = 'https://api.web3forms.com/submit';

    const okClass = 'text-sm font-medium text-emerald-600 dark:text-emerald-400';
    const errClass = 'text-sm font-medium text-red-600 dark:text-red-400';

    // WhatsApp fallback: if the POST fails, pre-fill the WhatsApp button with
    // whatever the visitor already typed so the lead is never lost.
    const waLink = form.querySelector<HTMLAnchorElement>('a[href*="wa.me"]');
    const waBase = waLink?.href ?? null;
    const fallback = form.querySelector<HTMLAnchorElement>('[data-form-fallback]');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.reportValidity()) return;

      btn.disabled = true;
      btn.textContent = btn.dataset.sendingLabel ?? '...';
      status.className = 'hidden';

      try {
        const res = await fetch(ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(Object.fromEntries(new FormData(form) as any)),
        });
        const data = await res.json();
        if (!data.success) throw new Error('submit failed');
        form.reset();
        status.textContent = status.dataset.success ?? '';
        status.className = okClass;
        fallback?.setAttribute('hidden', '');
        // Conversión del formulario (tracking sin cookies).
        if (navigator.sendBeacon) {
          navigator.sendBeacon(
            '/api/event',
            new Blob(
              [JSON.stringify({ event: 'form', label: 'contacto', lang: document.documentElement.lang || '' })],
              { type: 'application/json' }
            )
          );
        }
      } catch {
        status.textContent = status.dataset.error ?? '';
        status.className = errClass;
        const name = (form.querySelector('[name="name"]') as HTMLInputElement | null)?.value ?? '';
        const msg = (form.querySelector('[name="message"]') as HTMLTextAreaElement | null)?.value ?? '';
        const text = `Hola, soy ${name}. ${msg}`.trim();
        if (waLink && waBase) {
          waLink.href = `${waBase.split('?')[0]}?text=${encodeURIComponent(text)}`;
        }
        // Fallback visible: el lead sigue teniendo un camino directo.
        if (fallback) {
          fallback.href = `${fallback.href.split('?')[0]}?text=${encodeURIComponent(text)}`;
          fallback.removeAttribute('hidden');
        }
      } finally {
        btn.disabled = false;
        btn.textContent = btn.dataset.sendLabel ?? '';
      }
    });
  }

  document.addEventListener('astro:page-load', initContactForm);
</script>
