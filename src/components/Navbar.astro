---
const links = [
  { href: '#servicios',     label: 'Servicios' },
  { href: '#caso-classify', label: 'Casos'     },
  { href: '#contacto',      label: 'Contacto'  },
];
---

<header id="site-header" class="fixed inset-x-0 top-0 z-40">
  <div class="container-x">
    <nav
      class="mt-4 flex items-center justify-between gap-4 rounded-2xl border border-white/10
             bg-zinc-950/60 px-4 py-3 shadow-soft-xl backdrop-blur-xl transition-all duration-300"
      aria-label="Navegación principal"
    >
      <!-- ── Logo ────────────────────────────────────────────── -->
      <a
        href="/"
        class="group flex flex-none items-center gap-2.5 rounded-md
               focus-visible:outline-none focus-visible:ring-2
               focus-visible:ring-accent-400 focus-visible:ring-offset-2
               focus-visible:ring-offset-zinc-950"
        aria-label="Efi Solution — Inicio"
      >
        <span class="relative flex h-7 w-7 flex-none items-center justify-center
                     rounded-lg bg-accent-500/15 ring-1 ring-accent-500/30">
          <span aria-hidden="true"
                class="absolute inset-0 rounded-lg bg-accent-500/20 blur-md"></span>
          <svg
            viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"
            class="relative text-accent-300"
            fill="none" stroke="currentColor"
            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
          >
            <path d="M13 2L3 14h7l-1 8 10-12h-7z" />
          </svg>
        </span>
        <span class="font-display text-sm font-semibold tracking-tight text-white">
          Efi<span class="text-accent-400">.</span>Solution
        </span>
      </a>

      <!-- ── Desktop nav links ────────────────────────────────── -->
      <ul class="hidden items-center gap-1 md:flex" role="list">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="rounded-full px-4 py-2 text-sm text-zinc-400 transition-colors
                     hover:bg-white/[0.04] hover:text-white
                     focus-visible:outline-none focus-visible:ring-2
                     focus-visible:ring-accent-400 focus-visible:ring-offset-1
                     focus-visible:ring-offset-zinc-950"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- ── Right side: CTA + Hamburger ─────────────────────── -->
      <div class="flex items-center gap-2">
        <a
          href="#contacto"
          class="inline-flex items-center gap-2 rounded-full border border-white/10
                 bg-white/[0.04] px-4 py-2 text-sm font-medium text-zinc-100
                 transition-all hover:border-accent-500/40 hover:bg-accent-500/10 hover:text-white
                 focus-visible:outline-none focus-visible:ring-2
                 focus-visible:ring-accent-400 focus-visible:ring-offset-2
                 focus-visible:ring-offset-zinc-950"
        >
          Auditoría
          <span
            aria-hidden="true"
            class="inline-block h-1.5 w-1.5 flex-none rounded-full bg-accent-500
                   animate-pulse-slow"
            style="box-shadow: 0 0 8px 2px rgba(77,124,254,0.7);"
          ></span>
        </a>

        <!-- Hamburger button — mobile only -->
        <button
          id="hamburger"
          type="button"
          aria-label="Abrir menú de navegación"
          aria-expanded="false"
          aria-controls="mobile-nav"
          class="group relative flex h-9 w-9 flex-none items-center justify-center
                 rounded-lg border border-white/10 bg-white/[0.03] text-zinc-300
                 transition-colors hover:border-white/20 hover:text-white md:hidden
                 focus-visible:outline-none focus-visible:ring-2
                 focus-visible:ring-accent-400 focus-visible:ring-offset-2
                 focus-visible:ring-offset-zinc-950"
        >
          <!-- Animated hamburger → X icon via aria-expanded CSS -->
          <span aria-hidden="true" class="flex h-4 w-4 flex-col items-center justify-between">
            <span class="hamburger-bar block h-px w-full origin-center bg-current
                         transition-all duration-300 ease-in-out"></span>
            <span class="hamburger-bar block h-px w-full bg-current
                         transition-all duration-300 ease-in-out"></span>
            <span class="hamburger-bar block h-px w-full origin-center bg-current
                         transition-all duration-300 ease-in-out"></span>
          </span>
        </button>
      </div>
    </nav>
  </div>

  <!-- ── Mobile menu panel ─────────────────────────────────────── -->
  <div
    id="mobile-nav"
    role="dialog"
    aria-modal="false"
    aria-label="Menú de navegación"
    aria-hidden="true"
    class="container-x mt-2 hidden"
  >
    <div class="rounded-2xl border border-white/10 bg-zinc-950/95 px-3 py-3 shadow-soft-xl
                backdrop-blur-xl">
      <ul class="flex flex-col" role="list">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              data-mobile-close
              class="flex w-full items-center rounded-xl px-4 py-3 text-sm font-medium
                     text-zinc-300 transition-colors hover:bg-white/[0.04] hover:text-white
                     focus-visible:outline-none focus-visible:ring-2
                     focus-visible:ring-accent-400 focus-visible:ring-inset"
            >
              {l.label}
            </a>
          </li>
        ))}

        <li class="mt-2 border-t border-white/[0.06] pt-2">
          <a
            href="#contacto"
            data-mobile-close
            class="flex w-full items-center justify-center gap-2 rounded-xl
                   bg-accent-500 px-4 py-3 text-sm font-semibold text-white
                   transition-colors hover:bg-accent-400
                   focus-visible:outline-none focus-visible:ring-2
                   focus-visible:ring-accent-400 focus-visible:ring-offset-2
                   focus-visible:ring-offset-zinc-950"
          >
            Agendar Auditoría Gratuita
            <span aria-hidden="true"
                  class="h-1.5 w-1.5 flex-none rounded-full bg-white/70
                         animate-pulse-slow"></span>
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<style>
  /* Hamburger → X animation driven by aria-expanded */
  #hamburger[aria-expanded="true"] .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  #hamburger[aria-expanded="true"] .hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  #hamburger[aria-expanded="true"] .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>

<script>
  const header  = document.getElementById('site-header') as HTMLElement | null;
  const btn     = document.getElementById('hamburger')  as HTMLButtonElement | null;
  const menu    = document.getElementById('mobile-nav') as HTMLElement | null;

  // ── Scroll state: darken nav on scroll ───────────────────────
  window.addEventListener('scroll', () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 40);
  }, { passive: true });

  // ── Toggle mobile menu ────────────────────────────────────────
  function openMenu(): void {
    if (!btn || !menu) return;
    btn.setAttribute('aria-expanded', 'true');
    menu.setAttribute('aria-hidden', 'false');
    menu.classList.remove('hidden');
    // Focus first link for keyboard users
    (menu.querySelector('a') as HTMLElement | null)?.focus();
  }

  function closeMenu(): void {
    if (!btn || !menu) return;
    btn.setAttribute('aria-expanded', 'false');
    menu.setAttribute('aria-hidden', 'true');
    menu.classList.add('hidden');
  }

  btn?.addEventListener('click', (e) => {
    e.stopPropagation();
    btn.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu();
  });

  // Close on any nav link click
  menu?.querySelectorAll<HTMLAnchorElement>('[data-mobile-close]').forEach((el) => {
    el.addEventListener('click', closeMenu);
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (menu && !header?.contains(e.target as Node)) closeMenu();
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && btn?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
      btn.focus();
    }
  });
</script>
