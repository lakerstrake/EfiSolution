---
import { getSiteContent, localeHref, type Locale } from '../i18n/siteContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getSiteContent(locale);

const langs: Array<{ code: Locale; label: string }> = [
  { code: 'es', label: 'ES' },
  { code: 'en', label: 'EN' },
  { code: 'pt', label: 'PT' },
];
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50 px-4 pt-4 sm:px-6">
  <div class="container-x">
    <nav
      class="header-shell flex items-center justify-between rounded-2xl border border-zinc-200/70 bg-white/75 px-4 py-3 backdrop-blur-xl transition-all duration-300 dark:border-white/10 dark:bg-zinc-950/65"
      aria-label={t.nav.mainLabel}
    >
      <a href={localeHref(locale)} class="inline-flex items-center gap-2.5 rounded-md">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg border border-accent-500/30 bg-accent-500/10 text-accent-500">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13 2L3 14h7l-1 8 10-12h-7z" />
          </svg>
        </span>
        <span class="font-display text-sm font-semibold text-zinc-900 dark:text-white">Efi Solution</span>
      </a>

      <ul class="hidden items-center gap-1 md:flex" role="list">
        {t.nav.links.map((link) => (
          <li>
            <a
              href={link.href}
              class="rounded-full px-4 py-2 text-sm font-medium text-zinc-600 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="flex items-center gap-2">
        <div class="hidden items-center gap-1 rounded-full border border-zinc-200/80 bg-white/70 p-1 dark:border-white/10 dark:bg-white/[0.04] md:flex">
          {langs.map((item) => (
            <a
              href={localeHref(item.code)}
              aria-current={item.code === locale ? 'page' : undefined}
              class={`rounded-full px-2.5 py-1 text-xs font-semibold transition-colors ${
                item.code === locale
                  ? 'bg-accent-500 text-white'
                  : 'text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white'
              }`}
            >
              {item.label}
            </a>
          ))}
        </div>

        <button
          id="theme-toggle"
          type="button"
          aria-label={t.nav.themeToggle}
          class="flex h-9 w-9 items-center justify-center rounded-xl border border-zinc-200/80 bg-white/70 text-zinc-600 transition-colors hover:text-zinc-900 dark:border-white/10 dark:bg-white/[0.04] dark:text-zinc-300 dark:hover:text-white"
        >
          <svg id="icon-moon" class="h-[18px] w-[18px] dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
          </svg>
          <svg id="icon-sun" class="hidden h-[18px] w-[18px] text-amber-400 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
          </svg>
        </button>

        <a
          href="#contacto"
          class="hidden rounded-full bg-accent-500 px-4 py-2 text-sm font-semibold text-white shadow-[0_10px_30px_-10px_rgba(11,84,253,0.65)] transition-colors hover:bg-accent-600 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-200 md:inline-flex"
        >
          {t.nav.cta}
        </a>

        <button
          id="hamburger"
          type="button"
          aria-label={t.nav.mobileMenu}
          aria-expanded="false"
          aria-controls="mobile-nav"
          class="flex h-9 w-9 items-center justify-center rounded-xl border border-zinc-200/80 bg-white/70 text-zinc-600 transition-colors hover:text-zinc-900 dark:border-white/10 dark:bg-white/[0.04] dark:text-zinc-300 dark:hover:text-white md:hidden"
        >
          <span class="flex h-4 w-4 flex-col items-center justify-between" aria-hidden="true">
            <span class="hamburger-bar h-px w-full bg-current transition-all duration-300"></span>
            <span class="hamburger-bar h-px w-full bg-current transition-all duration-300"></span>
            <span class="hamburger-bar h-px w-full bg-current transition-all duration-300"></span>
          </span>
        </button>
      </div>
    </nav>
  </div>

  <div id="mobile-nav" class="container-x mt-2 hidden" aria-hidden="true">
    <div class="rounded-2xl border border-zinc-200/80 bg-white/95 p-3 shadow-sm backdrop-blur dark:border-white/10 dark:bg-zinc-950/95">
      <ul class="space-y-1" role="list">
        {t.nav.links.map((link) => (
          <li>
            <a
              href={link.href}
              data-mobile-close
              class="block rounded-xl px-4 py-3 text-sm font-medium text-zinc-700 hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-white/[0.05]"
            >
              {link.label}
            </a>
          </li>
        ))}
        <li class="pt-2">
          <a
            href="#contacto"
            data-mobile-close
            class="flex items-center justify-center rounded-xl bg-accent-500 px-4 py-3 text-sm font-semibold text-white hover:bg-accent-600 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-200"
          >
            {t.nav.cta}
          </a>
        </li>
      </ul>
      <div class="mt-3 flex items-center justify-center gap-2 border-t border-zinc-200/80 pt-3 dark:border-white/10">
        {langs.map((item) => (
          <a
            href={localeHref(item.code)}
            class={`rounded-full px-3 py-1 text-xs font-semibold ${
              item.code === locale
                ? 'bg-accent-500 text-white'
                : 'border border-zinc-300 text-zinc-700 dark:border-white/20 dark:text-zinc-300'
            }`}
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<style>
  #hamburger[aria-expanded='true'] .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  #hamburger[aria-expanded='true'] .hamburger-bar:nth-child(2) {
    opacity: 0;
  }
  #hamburger[aria-expanded='true'] .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>

<script>
  const header = document.getElementById('site-header') as HTMLElement | null;
  if (header && header.dataset.bound !== 'true') {
    header.dataset.bound = 'true';
    const themeToggle = document.getElementById('theme-toggle');
    const btn = document.getElementById('hamburger');
    const menu = document.getElementById('mobile-nav');

    window.addEventListener(
      'scroll',
      () => {
        header.classList.toggle('is-scrolled', window.scrollY > 18);
      },
      { passive: true }
    );

    themeToggle?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      const newTheme = isDark ? 'light' : 'dark';
      document.documentElement.classList.toggle('dark', newTheme === 'dark');
      localStorage.setItem('theme', newTheme);

      const metaThemeColor = document.getElementById('meta-theme-color');
      if (metaThemeColor) {
        metaThemeColor.setAttribute('content', newTheme === 'dark' ? '#09090b' : '#f8fafc');
      }
    });

    function closeMenu() {
      if (!btn || !menu) return;
      btn.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
      menu.classList.add('hidden');
    }

    btn?.addEventListener('click', () => {
      if (!menu || !btn) return;
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      menu.setAttribute('aria-hidden', String(expanded));
      menu.classList.toggle('hidden', expanded);
    });

    menu?.querySelectorAll('[data-mobile-close]').forEach((item) => {
      item.addEventListener('click', () => setTimeout(closeMenu, 100));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
  }
</script>
