---
const links = [
  { href: '#servicios', label: 'Servicios' },
  { href: '#caso-classify', label: 'Casos' },
  { href: '#contacto', label: 'Contacto' },
];
---

<header class="fixed inset-x-0 top-0 z-40">
  <div class="container-x">
    <nav
      class="mt-4 flex items-center justify-between rounded-2xl border border-white/10 bg-zinc-950/60 px-4 py-3 backdrop-blur-xl shadow-soft-xl"
      aria-label="Navegación principal"
    >
      <a href="/" class="flex items-center gap-2.5 group" aria-label="Efi Solution — Inicio">
        <span class="relative flex h-7 w-7 items-center justify-center rounded-lg bg-accent-500/15 ring-1 ring-accent-500/30">
          <span class="absolute inset-0 rounded-lg bg-accent-500/20 blur-md"></span>
          <svg viewBox="0 0 24 24" width="14" height="14" class="relative text-accent-300" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13 2L3 14h7l-1 8 10-12h-7z" />
          </svg>
        </span>
        <span class="font-display text-sm font-semibold tracking-tight text-white">
          Efi<span class="text-accent-400">.</span>Solution
        </span>
      </a>

      <ul class="hidden items-center gap-1 md:flex">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="rounded-full px-4 py-2 text-sm text-zinc-400 transition-colors hover:bg-white/[0.04] hover:text-white"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>

      <a
        href="#contacto"
        class="inline-flex items-center gap-2 rounded-full bg-white/[0.04] border border-white/10 px-4 py-2 text-sm font-medium text-zinc-100 transition-all hover:border-accent-500/40 hover:bg-accent-500/10 hover:text-white"
      >
        Auditoría
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent-500 shadow-[0_0_8px_2px_rgba(77,124,254,0.7)] animate-pulse-slow"></span>
      </a>
    </nav>
  </div>
</header>
