---
import { getSiteContent, type Locale } from '../i18n/siteContent';
import { whatsappHref } from '../lib/whatsapp';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getSiteContent(locale).ai;
const waHref = whatsappHref(t.waMessage);
---

<section id="ia" class="section-padding" aria-labelledby="ai-title">
  <div class="container-x">
    <div class="reveal surface relative overflow-hidden p-7 sm:p-10 lg:p-12">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
        <div class="absolute -right-24 -top-16 h-72 w-72 rounded-full bg-accent-500/12 blur-[120px]"></div>
        <div class="absolute -left-24 bottom-0 h-64 w-64 rounded-full bg-accent-500/10 blur-[110px]"></div>
      </div>

      <div class="grid gap-10 lg:grid-cols-12 lg:gap-14 lg:items-center">
        <div class="min-w-0 lg:col-span-5">
          <span class="eyebrow">
            <span class="eyebrow-dot"></span>
            {t.badge}
          </span>

          <h2 id="ai-title" class="mt-6 font-display text-fluid-4xl font-semibold leading-[1.06] tracking-tightest text-zinc-900 dark:text-white">
            {t.title}
          </h2>

          <p class="mt-5 max-w-xl text-fluid-base leading-relaxed text-zinc-600 dark:text-zinc-400">
            {t.description}
          </p>

          <dl class="mt-8 grid gap-5 sm:grid-cols-3">
            {t.benefits.map((benefit) => (
              <div class="rounded-2xl border border-zinc-200/80 bg-white/60 p-4 dark:border-white/10 dark:bg-white/[0.03]">
                <dt class="font-display text-sm font-semibold text-zinc-900 dark:text-white">{benefit.title}</dt>
                <dd class="mt-1.5 text-[13px] leading-relaxed text-zinc-600 dark:text-zinc-400">{benefit.body}</dd>
              </div>
            ))}
          </dl>

          {waHref && (
            <a
              href={waHref}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-8 inline-flex items-center gap-2 rounded-full bg-accent-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-600 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-200"
            >
              {t.cta}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14" /><path d="M12 5l7 7-7 7" />
              </svg>
            </a>
          )}
        </div>

        <!-- Demo REAL del panel de Búho: la IA llena el inventario a partir de una
             foto. Animación CSS en bucle (antes → escaneo IA → después). -->
        <aside class="min-w-0 lg:col-span-7">
          <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-accent-600 dark:text-accent-400">{t.exampleTag}</p>
          <figure class="scroll-parallax overflow-hidden rounded-3xl border border-zinc-200/80 bg-white/70 shadow-[0_26px_70px_-34px_rgba(11,84,253,0.55)] dark:border-white/10 dark:bg-zinc-900/50">
            <div class="flex items-center gap-2 border-b border-zinc-200/80 px-3.5 py-2.5 dark:border-white/10">
              <span class="h-2.5 w-2.5 rounded-full bg-red-500/70"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-amber-500/70"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-emerald-500/70"></span>
              <span class="ml-2 truncate text-[11px] font-medium text-zinc-500">{t.frameLabel}</span>
            </div>

            <div class="buho-stage relative aspect-[16/9] w-full overflow-hidden bg-zinc-100 dark:bg-zinc-900">
              <picture>
                <source srcset="/buho-ia-1.avif" type="image/avif" />
                <source srcset="/buho-ia-1.webp" type="image/webp" />
                <img src="/buho-ia-1.png" alt={t.beforeAlt} width="1120" height="630" loading="eager" decoding="async" class="buho-before absolute inset-0 h-full w-full object-cover object-top" />
              </picture>
              <picture>
                <source srcset="/buho-ia-2.avif" type="image/avif" />
                <source srcset="/buho-ia-2.webp" type="image/webp" />
                <img src="/buho-ia-2.png" alt={t.exampleText} width="1120" height="630" loading="lazy" decoding="async" class="buho-after absolute inset-0 h-full w-full object-cover object-top" />
              </picture>

              <span class="buho-scan" aria-hidden="true"></span>

              <span class="buho-pill buho-pill-before absolute left-3 top-3 rounded-full bg-zinc-900/80 px-2.5 py-1 text-[11px] font-semibold text-white backdrop-blur">{t.beforeLabel}</span>
              <span class="buho-pill buho-pill-after absolute left-3 top-3 rounded-full bg-accent-500 px-2.5 py-1 text-[11px] font-semibold text-white">{t.afterLabel}</span>

              <span class="buho-badge buho-badge-scan absolute bottom-3 left-1/2 inline-flex items-center gap-2 rounded-full bg-accent-600/95 px-4 py-2 text-xs font-semibold text-white shadow-lg">
                <svg class="buho-spin" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M21 12a9 9 0 1 1-6.219-8.56" /></svg>
                {t.scanLabel}
              </span>
              <span class="buho-badge buho-badge-done absolute bottom-3 left-1/2 inline-flex items-center gap-2 rounded-full bg-emerald-500/95 px-4 py-2 text-xs font-semibold text-white shadow-lg">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
                {t.doneLabel}
              </span>
            </div>

            <figcaption class="relative min-h-[3.25rem] border-t border-zinc-200/80 px-4 py-3 text-xs leading-snug text-zinc-600 dark:border-white/10 dark:text-zinc-400">
              <span class="buho-cap-before absolute inset-x-4 top-3 flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-zinc-400"></span>{t.flowPhoto}</span>
              <span class="buho-cap-after absolute inset-x-4 top-3 flex items-center gap-2"><span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>{t.flowResult}</span>
            </figcaption>
          </figure>
        </aside>
      </div>
    </div>
  </div>
</section>

<style>
  .buho-before { animation: buhoBefore 7s ease-in-out infinite; }
  .buho-after  {
    opacity: 0;
    transform-origin: top center;
    will-change: opacity, transform;
    animation: buhoAfter 7s ease-in-out infinite, buhoAfterZoom 7s ease-in-out infinite;
  }
  /* Push-in sutil (Ken Burns) mientras el "después" está visible; el salto de
     vuelta a scale(1) ocurre con opacidad 0, así que nunca se percibe. */
  @keyframes buhoAfterZoom { 0%,49% { transform: scale(1); } 95%,100% { transform: scale(1.04); } }

  .buho-scan {
    position: absolute;
    left: 0; right: 0; top: 0;
    height: 22%;
    pointer-events: none;
    opacity: 0;
    mix-blend-mode: screen;
    background: linear-gradient(to bottom, transparent, rgba(11,84,253,0.16), rgba(11,84,253,0.5), rgba(11,84,253,0.16), transparent);
    box-shadow: 0 0 34px 8px rgba(11,84,253,0.45);
    animation: buhoScan 7s linear infinite;
  }

  .buho-pill-before { animation: buhoPillBefore 7s ease-in-out infinite; }
  .buho-pill-after  { opacity: 0; animation: buhoPillAfter 7s ease-in-out infinite; }

  .buho-badge { transform: translateX(-50%); }
  .buho-badge-scan { opacity: 0; animation: buhoBadgeScan 7s ease-in-out infinite; }
  .buho-badge-done { opacity: 0; animation: buhoBadgeDone 7s ease-in-out infinite; }
  .buho-spin { animation: buhoSpin 0.9s linear infinite; }

  .buho-cap-before { animation: buhoCapBefore 7s ease-in-out infinite; }
  .buho-cap-after  { opacity: 0; animation: buhoCapAfter 7s ease-in-out infinite; }

  @keyframes buhoBefore { 0%,45% { opacity: 1; } 55%,93% { opacity: 0; } 100% { opacity: 1; } }
  @keyframes buhoAfter  { 0%,49% { opacity: 0; } 59%,95% { opacity: 1; } 100% { opacity: 0; } }
  @keyframes buhoScan {
    0%,28%   { opacity: 0; transform: translateY(-120%); }
    32%      { opacity: 1; }
    50%      { opacity: 1; transform: translateY(360%); }
    55%,100% { opacity: 0; transform: translateY(360%); }
  }
  @keyframes buhoBadgeScan {
    0%,27%   { opacity: 0; transform: translateX(-50%) translateY(6px); }
    33%,50%  { opacity: 1; transform: translateX(-50%) translateY(0); }
    56%,100% { opacity: 0; transform: translateX(-50%) translateY(6px); }
  }
  @keyframes buhoBadgeDone {
    0%,58%   { opacity: 0; transform: translateX(-50%) translateY(6px) scale(0.92); }
    65%,90%  { opacity: 1; transform: translateX(-50%) translateY(0) scale(1); }
    96%,100% { opacity: 0; transform: translateX(-50%) translateY(0) scale(1); }
  }
  @keyframes buhoPillBefore { 0%,46% { opacity: 1; } 54%,100% { opacity: 0; } }
  @keyframes buhoPillAfter  { 0%,57% { opacity: 0; } 63%,95% { opacity: 1; } 100% { opacity: 0; } }
  @keyframes buhoCapBefore  { 0%,46% { opacity: 1; } 56%,100% { opacity: 0; } }
  @keyframes buhoCapAfter   { 0%,55% { opacity: 0; } 63%,95% { opacity: 1; } 100% { opacity: 0; } }
  @keyframes buhoSpin { to { transform: rotate(360deg); } }

  /* Con "reducir movimiento" activo (común en PCs de escritorio) evitamos el
     barrido y el giro —que pueden marear—, pero mantenemos un crossfade suave
     (solo opacidad) para que el antes→después se aprecie en cualquier equipo. */
  @media (prefers-reduced-motion: reduce) {
    .buho-scan, .buho-badge-scan { display: none; }
    .buho-spin { animation: none; }
    .buho-before, .buho-pill-before, .buho-cap-before { animation: buhoFadeBefore 8s ease-in-out infinite; }
    .buho-after, .buho-pill-after, .buho-cap-after, .buho-badge-done { animation: buhoFadeAfter 8s ease-in-out infinite; }
    .buho-badge-done { transform: translateX(-50%); }
    /* global.css anula TODAS las animaciones con `animation-duration: 0.01ms
       !important` (selector `*`, especificidad 0) bajo "reducir movimiento".
       Estas clases tienen mayor especificidad, así que el crossfade suave
       —solo opacidad, sin barridos— sí se reproduce en esos equipos. */
    .buho-before, .buho-pill-before, .buho-cap-before,
    .buho-after, .buho-pill-after, .buho-cap-after, .buho-badge-done {
      animation-duration: 8s !important;
      animation-iteration-count: infinite !important;
    }
  }
  @keyframes buhoFadeBefore { 0%, 40% { opacity: 1; } 55%, 90% { opacity: 0; } 100% { opacity: 1; } }
  @keyframes buhoFadeAfter  { 0%, 45% { opacity: 0; } 60%, 95% { opacity: 1; } 100% { opacity: 0; } }
</style>
