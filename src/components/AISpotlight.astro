---
import { getSiteContent, type Locale } from '../i18n/siteContent';
import { whatsappHref } from '../lib/whatsapp';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getSiteContent(locale).ai;
const waHref = whatsappHref(t.waMessage);
---

<section id="ia" class="section-padding" aria-labelledby="ai-title">
  <div class="container-x">
    <div class="reveal surface relative overflow-hidden p-7 sm:p-10 lg:p-12">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
        <div class="absolute -right-24 -top-16 h-72 w-72 rounded-full bg-accent-500/12 blur-[120px]"></div>
        <div class="absolute -left-24 bottom-0 h-64 w-64 rounded-full bg-accent-500/10 blur-[110px]"></div>
      </div>

      <div class="grid gap-10 lg:grid-cols-12 lg:gap-14">
        <div class="lg:col-span-6">
          <span class="eyebrow">
            <span class="eyebrow-dot"></span>
            {t.badge}
          </span>

          <h2 id="ai-title" class="mt-6 font-display text-fluid-4xl font-semibold leading-[1.06] tracking-tightest text-zinc-900 dark:text-white">
            {t.title}
          </h2>

          <p class="mt-5 max-w-xl text-fluid-base leading-relaxed text-zinc-600 dark:text-zinc-400">
            {t.description}
          </p>

          <dl class="mt-8 grid gap-5 sm:grid-cols-3">
            {t.benefits.map((benefit) => (
              <div class="rounded-2xl border border-zinc-200/80 bg-white/60 p-4 dark:border-white/10 dark:bg-white/[0.03]">
                <dt class="font-display text-sm font-semibold text-zinc-900 dark:text-white">{benefit.title}</dt>
                <dd class="mt-1.5 text-[13px] leading-relaxed text-zinc-600 dark:text-zinc-400">{benefit.body}</dd>
              </div>
            ))}
          </dl>

          {waHref && (
            <a
              href={waHref}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-8 inline-flex items-center gap-2 rounded-full bg-accent-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-accent-600 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-200"
            >
              {t.cta}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14" /><path d="M12 5l7 7-7 7" />
              </svg>
            </a>
          )}
        </div>

        <!-- Mini-demostración estilizada del flujo foto -> IA -> inventario.
             No usa imágenes (cero peso). TODO opcional: reemplazar el bloque
             "foto" por una captura real de Búho cuando esté disponible. -->
        <aside class="lg:col-span-6">
          <div class="rounded-3xl border border-zinc-200/80 bg-gradient-to-b from-white/80 to-white/40 p-5 shadow-sm dark:border-white/10 dark:from-white/[0.05] dark:to-transparent">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-accent-600 dark:text-accent-400">{t.exampleTag}</p>
            <p class="mt-3 text-sm leading-relaxed text-zinc-700 dark:text-zinc-300">{t.exampleText}</p>

            <div class="mt-5 flex items-stretch gap-3">
              <!-- Paso 1: la foto -->
              <div class="flex flex-1 flex-col items-center justify-center gap-2 rounded-2xl border border-dashed border-zinc-300 bg-zinc-100/70 p-4 text-center dark:border-white/15 dark:bg-white/[0.03]">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500" aria-hidden="true">
                  <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z" /><circle cx="12" cy="13" r="4" />
                </svg>
                <span class="text-[11px] font-medium leading-tight text-zinc-600 dark:text-zinc-400">{t.flowPhoto}</span>
              </div>

              <!-- Flecha IA -->
              <div class="flex flex-none items-center" aria-hidden="true">
                <div class="flex h-9 w-9 items-center justify-center rounded-full bg-accent-500/15 text-accent-600 dark:text-accent-400">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14" /><path d="M12 5l7 7-7 7" />
                  </svg>
                </div>
              </div>

              <!-- Paso 2: inventario lleno -->
              <div class="flex flex-1 flex-col justify-center gap-2 rounded-2xl border border-accent-500/30 bg-accent-500/[0.06] p-4 dark:bg-accent-500/10">
                <div class="space-y-1.5" aria-hidden="true">
                  <div class="h-2 w-3/4 rounded-full bg-accent-500/50"></div>
                  <div class="h-2 w-full rounded-full bg-zinc-300 dark:bg-white/15"></div>
                  <div class="h-2 w-5/6 rounded-full bg-zinc-300 dark:bg-white/15"></div>
                  <div class="h-2 w-2/3 rounded-full bg-accent-500/40"></div>
                </div>
                <span class="mt-1 text-[11px] font-medium leading-tight text-zinc-700 dark:text-zinc-300">{t.flowResult}</span>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>
</section>
