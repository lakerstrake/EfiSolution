---
import { getSiteContent, type Locale } from '../i18n/siteContent';
import { whatsappHref } from '../lib/whatsapp';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getSiteContent(locale).clientCase;
const waHref = whatsappHref(t.waMessage);
const siteUrl = 'https://buhorepuestos.com';
---

<section id="cliente" class="section-padding" aria-labelledby="client-case-title">
  <div class="container-x">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow border-emerald-500/30 bg-emerald-500/10 text-emerald-700 dark:text-emerald-400">
        <span class="eyebrow-dot" style="background-color:#10b981;box-shadow:0 0 14px 2px rgba(16,185,129,0.45)"></span>
        {t.badge}
      </span>
      <h2 id="client-case-title" class="mt-6 font-display text-fluid-4xl font-semibold leading-[1.06] tracking-tightest text-zinc-900 dark:text-white">
        {t.title}
      </h2>
    </div>

    <div class="reveal surface mt-10 grid gap-8 p-6 sm:p-8 lg:grid-cols-12 lg:gap-12 lg:p-10">
      <!-- Columna izquierda: la historia del cliente -->
      <div class="lg:col-span-7">
        <div class="flex flex-wrap items-center gap-3">
          <span class="flex h-12 w-12 items-center justify-center rounded-xl border border-zinc-200 bg-zinc-100 font-display text-sm font-bold text-zinc-700 dark:border-white/10 dark:bg-zinc-900 dark:text-zinc-200" aria-hidden="true">BR</span>
          <div>
            <p class="font-display text-lg font-semibold text-zinc-900 dark:text-white">{t.name}</p>
            <p class="text-xs uppercase tracking-[0.14em] text-zinc-500">{t.sector}</p>
          </div>
          <span class="ml-auto rounded-full border border-emerald-500/30 bg-emerald-500/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-emerald-700 dark:text-emerald-400">{t.realLabel}</span>
        </div>

        <div class="mt-7 space-y-7">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">{t.problemLabel}</p>
            <p class="mt-2 text-fluid-base leading-relaxed text-zinc-700 dark:text-zinc-300">{t.problem}</p>
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">{t.builtLabel}</p>
            <ul class="mt-3 grid gap-2 sm:grid-cols-2">
              {t.built.map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-zinc-700 dark:text-zinc-300">
                  <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="mt-1 flex-none text-accent-500"><polyline points="20 6 9 17 4 12" /></svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">{t.resultsLabel}</p>
            <ul class="mt-3 space-y-2">
              {t.results.map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-zinc-700 dark:text-zinc-300">
                  <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" class="mt-1 flex-none text-emerald-500"><path d="M20 6 9 17l-5-5" /></svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href={siteUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full bg-accent-500 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-accent-600">
            {t.visit}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" /></svg>
          </a>
          {waHref && (
            <a href={waHref} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white/70 px-5 py-2.5 text-sm font-semibold text-zinc-800 transition-colors hover:border-zinc-300 dark:border-white/15 dark:bg-white/[0.03] dark:text-zinc-100">
              {t.cta}
            </a>
          )}
        </div>
      </div>

      <!-- Columna derecha: vista real del sitio del cliente -->
      <aside class="lg:col-span-5">
        <a href={siteUrl} target="_blank" rel="noopener noreferrer" aria-label={`${t.visit}: ${t.name}`} class="group/media block overflow-hidden rounded-2xl border border-zinc-200 bg-zinc-100 shadow-sm transition-transform duration-300 hover:scale-[1.01] dark:border-white/10 dark:bg-zinc-900">
          <div class="flex items-center gap-2 border-b border-zinc-200 px-3 py-2 dark:border-white/10">
            <span class="h-2 w-2 rounded-full bg-red-500/60"></span>
            <span class="h-2 w-2 rounded-full bg-amber-500/60"></span>
            <span class="h-2 w-2 rounded-full bg-emerald-500/60"></span>
          </div>
          <div class="aspect-[16/10] w-full overflow-hidden">
            <picture>
              <source srcset="/buho.avif" type="image/avif" />
              <source srcset="/buho.webp" type="image/webp" />
              <img src="/buho.png" alt={t.name} width="800" height="500" loading="lazy" decoding="async" class="h-full w-full object-cover object-top" />
            </picture>
          </div>
        </a>
      </aside>
    </div>
  </div>
</section>
