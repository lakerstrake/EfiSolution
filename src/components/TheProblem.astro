---
import { getSiteContent, type Locale } from '../i18n/siteContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getSiteContent(locale).problem;
---

<section id="problema" class="section-padding" aria-labelledby="problem-title">
  <div class="container-x">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-5">
        <span class="eyebrow">
          <span class="eyebrow-dot"></span>
          {t.badge}
        </span>

        <h2 id="problem-title" class="mt-6 font-display text-fluid-4xl font-semibold leading-[1.06] tracking-tightest text-zinc-900 dark:text-white">
          {t.titleA} <span class="text-accent-500">{t.titleB}</span>
        </h2>

        <p class="mt-5 max-w-md text-fluid-base leading-relaxed text-zinc-700 dark:text-zinc-400">
          {t.description}
        </p>

        <div class="kpi-grid mt-8 grid-cols-2">
          <div class="kpi-item">
            <p class="font-display text-fluid-3xl font-semibold text-zinc-900 dark:text-white">53%</p>
            <p class="mt-1 text-xs text-zinc-500">{t.statA}</p>
          </div>
          <div class="kpi-item">
            <p class="font-display text-fluid-3xl font-semibold text-zinc-900 dark:text-white">7%</p>
            <p class="mt-1 text-xs text-zinc-500">{t.statB}</p>
          </div>
        </div>
      </div>

      <ol class="space-y-7 lg:col-span-7" aria-label={t.sequenceLabel}>
        {t.blocks.map((block, index) => (
          <li class="surface p-6 sm:p-7">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">0{index + 1} · {block.tag}</p>
            <h3 class="mt-3 font-display text-fluid-2xl font-semibold text-zinc-900 dark:text-white">{block.headline}</h3>
            <p class="mt-3 text-fluid-base leading-relaxed text-zinc-700 dark:text-zinc-400">{block.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
