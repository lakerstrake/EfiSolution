---
import { getSiteContent, type Locale } from '../i18n/siteContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getSiteContent(locale).problem;
---

<section id="problema" class="cv-auto section-padding" aria-labelledby="problem-title">
  <div class="container-x">
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-14">

      <div class="min-w-0 lg:col-span-5">
        <div class="reveal">
          <span class="eyebrow">
            <span class="eyebrow-dot"></span>
            {t.badge}
          </span>

          <h2 id="problem-title" class="mt-6 font-display text-fluid-4xl font-semibold leading-[1.06] tracking-tightest text-zinc-900 dark:text-white">
            {t.titleA} <span class="text-accent-500">{t.titleB}</span>
          </h2>

          <p class="mt-5 max-w-md text-fluid-base leading-relaxed text-zinc-600 dark:text-zinc-400">
            {t.description}
          </p>
        </div>

        <div class="reveal mt-8 grid grid-cols-2 gap-4">
          <div class="rounded-2xl border border-zinc-200/80 bg-white/70 p-5 dark:border-white/10 dark:bg-zinc-900/40">
            <p class="font-display text-[3rem] font-bold leading-none tracking-tightest text-zinc-900 dark:text-white">
              53<span class="text-accent-500">%</span>
            </p>
            <p class="mt-3 text-xs leading-relaxed text-zinc-500">{t.statA}</p>
          </div>
          <div class="rounded-2xl border border-zinc-200/80 bg-white/70 p-5 dark:border-white/10 dark:bg-zinc-900/40">
            <p class="font-display text-[3rem] font-bold leading-none tracking-tightest text-zinc-900 dark:text-white">
              7<span class="text-accent-500">%</span>
            </p>
            <p class="mt-3 text-xs leading-relaxed text-zinc-500">{t.statB}</p>
          </div>
        </div>
      </div>

      <ol class="min-w-0 space-y-5 lg:col-span-7" aria-label={t.sequenceLabel}>
        {t.blocks.map((block, index) => (
          <li
            class="reveal surface p-6 sm:p-7"
            style={`transition-delay: ${index * 100}ms`}
          >
            <div class="flex items-center gap-3">
              <span class="flex h-7 w-7 flex-none items-center justify-center rounded-full bg-accent-500/10 font-mono text-[11px] font-semibold text-accent-500 dark:bg-accent-500/20">
                0{index + 1}
              </span>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-zinc-500">{block.tag}</p>
            </div>
            <h3 class="mt-4 font-display text-fluid-2xl font-semibold text-zinc-900 dark:text-white">{block.headline}</h3>
            <p class="mt-3 text-fluid-base leading-relaxed text-zinc-600 dark:text-zinc-400">{block.body}</p>
          </li>
        ))}
      </ol>

    </div>
  </div>
</section>
