---
interface Props {
  index: number;
  number: string;
  title: string;
  description: string;
  bullets: string[];
  iconPath: string;
}

const { index, number, title, description, bullets, iconPath } = Astro.props;
---

<article
  class="reveal group surface flex h-full w-full flex-col p-7 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.12)] dark:hover:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.4)]"
  style={`transition-delay: ${index * 80}ms`}
>
  <div class="flex items-start justify-between">
    <span class="flex h-11 w-11 items-center justify-center rounded-xl border border-zinc-200 bg-zinc-100 text-accent-500 transition-all duration-300 group-hover:border-accent-500/30 group-hover:bg-accent-500/10 dark:border-white/10 dark:bg-white/[0.05] dark:text-accent-400">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d={iconPath} />
      </svg>
    </span>
    <span class="font-mono text-xs text-zinc-500">{number}</span>
  </div>

  <h3 class="mt-6 font-display text-fluid-xl font-semibold leading-tight text-zinc-900 dark:text-white">
    {title}
  </h3>

  <p class="mt-3 text-fluid-sm leading-relaxed text-zinc-700 dark:text-zinc-400">
    {description}
  </p>

  <ul class="mt-6 space-y-2 border-t border-zinc-200/80 pt-6 dark:border-white/10">
    {bullets.map((bullet) => (
      <li class="flex items-start gap-2.5 text-sm text-zinc-700 dark:text-zinc-300">
        <svg
          aria-hidden="true"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.4"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="mt-1 flex-none text-accent-500"
        >
          <polyline points="20 6 9 17 4 12" />
        </svg>
        <span>{bullet}</span>
      </li>
    ))}
  </ul>
</article>
