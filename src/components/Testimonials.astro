---
import { getSiteContent, type Locale } from '../i18n/siteContent';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getSiteContent(locale).testimonials;
---

<section id="testimonios" class="cv-auto section-padding" aria-labelledby="testimonials-title">
  <div class="container-x">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow border-amber-500/30 bg-amber-500/10 text-amber-700 dark:text-amber-400">
        <span class="eyebrow-dot" style="background-color:#f59e0b;box-shadow:0 0 14px 2px rgba(245,158,11,0.45)"></span>
        {t.badge}
      </span>
      <h2 id="testimonials-title" class="mt-6 font-display text-fluid-4xl font-semibold leading-[1.06] tracking-tightest text-zinc-900 dark:text-white">
        {t.title}
      </h2>
      <p class="mt-4 text-fluid-base leading-relaxed text-zinc-600 dark:text-zinc-400">
        {t.description}
      </p>
    </div>

    <div class="reveal mx-auto mt-10 grid max-w-3xl gap-6">
      {t.items.map((item) => (
        <figure class="surface relative flex h-full flex-col p-7 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.12)] dark:hover:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.4)] sm:p-9">
          <svg aria-hidden="true" width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="text-accent-500/15 dark:text-accent-500/25">
            <path d="M9.5 6C6.5 6 4 8.6 4 11.8V18h6.2v-6.2H7.6c0-1.7 1-2.9 2.6-3.2L9.5 6zm9.5 0c-3 0-5.5 2.6-5.5 5.8V18h6.2v-6.2h-2.6c0-1.7 1-2.9 2.6-3.2L19 6z" />
          </svg>

          <div class="mt-3 flex items-center gap-1" role="img" aria-label="5 de 5">
            {Array.from({ length: 5 }).map(() => (
              <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-amber-500">
                <path d="M12 2l2.9 6.3 6.9.7-5.1 4.6 1.4 6.8L12 17.8 5.9 20.4l1.4-6.8L2.2 9l6.9-.7L12 2z" />
              </svg>
            ))}
          </div>

          <blockquote class="mt-4 text-fluid-base leading-relaxed text-zinc-700 dark:text-zinc-200">
            “{item.quote}”
          </blockquote>

          {item.highlight && (
            <p class="mt-5 inline-flex w-fit items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-3 py-1 text-xs font-semibold text-emerald-700 dark:text-emerald-400">
              <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z" /></svg>
              {item.highlight}
            </p>
          )}

          <figcaption class="mt-7 flex flex-wrap items-center gap-x-3 gap-y-3 border-t border-zinc-200/80 pt-6 dark:border-white/10">
            {item.logo ? (
              <span class="flex h-11 w-11 flex-none items-center justify-center overflow-hidden rounded-full border border-zinc-200 bg-white shadow-sm dark:border-white/10">
                <picture>
                  <source srcset="/buho-logo.webp" type="image/webp" />
                  <img src={item.logo} alt={item.role} width="44" height="44" loading="lazy" decoding="async" class="h-full w-full object-cover" />
                </picture>
              </span>
            ) : (
              <span class="flex h-11 w-11 flex-none items-center justify-center rounded-full border border-zinc-200 bg-zinc-100 font-display text-sm font-bold text-zinc-700 dark:border-white/10 dark:bg-zinc-900 dark:text-zinc-200" aria-hidden="true">{item.initials}</span>
            )}
            <div class="min-w-0 flex-1">
              <p class="font-display text-sm font-semibold text-zinc-900 dark:text-white">{item.name}</p>
              <p class="text-xs leading-snug text-zinc-500">{item.role}</p>
            </div>
            <span class="ml-auto flex flex-none items-center gap-1.5 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.1em] text-emerald-700 dark:text-emerald-400">
              <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
              {t.verifiedLabel}
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
