---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import AISpotlight from '../../components/AISpotlight.astro';
import TheProblem from '../../components/TheProblem.astro';
import Services from '../../components/Services.astro';
import Approach from '../../components/Approach.astro';
import ClientCase from '../../components/ClientCase.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import Pricing from '../../components/Pricing.astro';
import FooterCTA from '../../components/FooterCTA.astro';
import { getSiteContent } from '../../i18n/siteContent';

const locale = 'fr' as const;
const t = getSiteContent(locale);
---

<Layout locale={locale} title={t.meta.title} description={t.meta.description}>
  <Hero locale={locale} />
  <AISpotlight locale={locale} />
  <TheProblem locale={locale} />
  <Services locale={locale} />
  <Approach locale={locale} />
  <ClientCase locale={locale} />
  <CaseStudy locale={locale} />
  <Pricing locale={locale} />
  <FooterCTA locale={locale} />
</Layout>
