---
import Layout from '../../layouts/Layout.astro';
import { privacy, privacyLabel } from '../../i18n/legal';
import { localeHref } from '../../i18n/siteContent';

const locale = 'fr' as const;
const t = privacy[locale];
---

<Layout locale={locale} title={`${privacyLabel[locale]} | Efi Solution`} description={t.intro}>
  <section class="section-padding pt-28 sm:pt-32">
    <div class="container-x">
      <div class="mx-auto max-w-3xl">
        <h1 class="font-display text-fluid-4xl font-semibold tracking-tightest text-zinc-900 dark:text-white">{t.title}</h1>
        <p class="mt-3 text-sm text-zinc-500">{t.updated}</p>
        <p class="mt-6 text-fluid-base leading-relaxed text-zinc-700 dark:text-zinc-300">{t.intro}</p>
        {t.sections.map((s) => (
          <div class="mt-8">
            <h2 class="font-display text-xl font-semibold text-zinc-900 dark:text-white">{s.h}</h2>
            <p class="mt-2 text-fluid-base leading-relaxed text-zinc-700 dark:text-zinc-400">{s.p}</p>
          </div>
        ))}
        <a
          href={localeHref(locale)}
          class="mt-10 inline-flex items-center gap-2 rounded-full border border-zinc-200 px-5 py-2.5 text-sm font-semibold text-zinc-800 transition-colors hover:bg-zinc-50 dark:border-white/15 dark:text-zinc-100 dark:hover:bg-white/[0.05]"
        >
          {t.backHome}
        </a>
      </div>
    </div>
  </section>
</Layout>
